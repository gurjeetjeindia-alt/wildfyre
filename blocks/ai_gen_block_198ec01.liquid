      "type": "textarea",
      "id": "review_2_text",
      "label": "Review text",
      "default": "This perfume exceeded all my expectations. The scent is sophisticated, long-lasting, and receives compliments everywhere I go. Worth every penny."
    },
    {
      "type": "text",
      "id": "review_2_author",
      "label": "Author name",
      "default": "Sarah M."
    },
    {
      "type": "text",
      "id": "review_2_date",
      "label": "Review date",
      "default": "January 10, 2026"
    },
    {
      "type": "checkbox",
      "id": "review_2_verified",
      "label": "Verified purchase",
      "default": true
    },
    {
      "type": "textarea",
      "id": "review_2_response",
      "label": "Brand response"
    },
    {
      "type": "header",
      "content": "Review 3"
    },
    {
      "type": "range",
      "id": "review_3_rating",
