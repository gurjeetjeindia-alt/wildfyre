      "label": "Title",
      "default": "Customer Reviews"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size (px)",
      "min": 24,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "Rating Distribution (percentage)"
    },
    {
      "type": "range",
      "id": "rating_bar_5",
      "label": "5★ bar width %",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 92
    },
    {
      "type": "range",
      "id": "rating_bar_4",
      "label": "4★ bar width %",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "rating_bar_3",
