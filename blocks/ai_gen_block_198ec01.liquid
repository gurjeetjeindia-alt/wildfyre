{% doc %}
  @prompt
    create a review section just like the dossier website we want same ui like that website https://dossier.co/products/ambery-saffron?Size=100ml this is the link, these are having cards we need a section like things
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=Inter:wght@300;400;500;600;700&display=swap');

  .dossier-reviews-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    font-family: 'Inter', sans-serif;
    color: #000;
  }

  .dossier-reviews-{{ ai_gen_id }} .dossier-reviews-title {
    font-family: 'EB Garamond', serif;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 500;
    margin: 0 0 {{ block.settings.section_padding | divided_by: 2 }}px 0;
    line-height: 1.2;
    color: #000;
  }

  .dossier-reviews-layout-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  @media screen and (min-width: 990px) {
    .dossier-reviews-layout-{{ ai_gen_id }} {
      flex-direction: row;
      gap: 5rem;
    }
  }

  .dossier-reviews-sidebar-{{ ai_gen_id }} {
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .dossier-reviews-sidebar-{{ ai_gen_id }} {
      width: 33.333%;
      flex-shrink: 0;
    }
  }

  .dossier-reviews-main-{{ ai_gen_id }} {
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .dossier-reviews-main-{{ ai_gen_id }} {
      width: 66.666%;
    }
  }

  .dossier-rating-large-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .dossier-rating-number-{{ ai_gen_id }} {
    font-family: 'EB Garamond', serif;
    font-size: 4rem;
    font-weight: 500;
    line-height: 1;
    color: #000;
  }

  .dossier-rating-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 0.25rem;
  }

  .dossier-rating-star-{{ ai_gen_id }} {
    width: 1.25rem;
    height: 1.25rem;
    fill: #fbbf24;
  }

  .dossier-rating-star-{{ ai_gen_id }}.empty {
    fill: #e5e7eb;
  }

  .dossier-rating-label-{{ ai_gen_id }} {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 1.5rem;
  }

  .dossier-rating-bars-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .dossier-rating-bar-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .dossier-rating-bar-label-{{ ai_gen_id }} {
    width: 1rem;
    font-size: 0.875rem;
    color: #000;
  }

  .dossier-rating-bar-track-{{ ai_gen_id }} {
    flex: 1;
    height: 0.5rem;
    background: #f3f4f6;
    border-radius: 9999px;
    overflow: hidden;
  }

  .dossier-rating-bar-fill-{{ ai_gen_id }} {
    height: 100%;
    background: #000;
    border-radius: 9999px;
  }

  .dossier-rating-bar-count-{{ ai_gen_id }} {
    width: 3rem;
    text-align: right;
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .dossier-write-review-btn-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 0.75rem;
    background: #fff;
    color: #000;
    border: 1px solid #000;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    text-align: center;
    font-family: 'Inter', sans-serif;
  }

  .dossier-write-review-btn-{{ ai_gen_id }}:hover {
    background: #000;
    color: #fff;
  }

  .dossier-reviews-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f3f4f6;
    margin-bottom: 0;
  }

  .dossier-reviews-tab-group-{{ ai_gen_id }} {
    display: flex;
    gap: 1rem;
  }

  .dossier-reviews-tab-{{ ai_gen_id }} {
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: underline;
    background: none;
    border: none;
    cursor: pointer;
    color: #000;
    padding: 0;
    font-family: 'Inter', sans-serif;
  }

  .dossier-reviews-tab-{{ ai_gen_id }}.inactive {
    color: #9ca3af;
    text-decoration: none;
    font-weight: 400;
  }

  .dossier-reviews-sort-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .dossier-reviews-sort-select-{{ ai_gen_id }} {
    border: none;
    background: transparent;
    font-weight: 700;
    color: #000;
    cursor: pointer;
    font-size: 0.875rem;
    font-family: 'Inter', sans-serif;
    padding: 0;
  }

  .dossier-reviews-sort-select-{{ ai_gen_id }}:focus {
    outline: none;
  }

  .dossier-reviews-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .dossier-review-item-{{ ai_gen_id }} {
    padding: 2.5rem 0;
    border-bottom: 1px solid #f3f4f6;
  }

  .dossier-review-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .dossier-review-item-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .dossier-review-author-block-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .dossier-review-avatar-{{ ai_gen_id }} {
    width: 2.5rem;
    height: 2.5rem;
    background: #f3f4f6;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75rem;
    color: #9ca3af;
    flex-shrink: 0;
  }

  .dossier-review-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .dossier-review-author-name-{{ ai_gen_id }} {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000;
  }

  .dossier-review-author-name-{{ ai_gen_id }} .verified-badge {
    margin-left: 0.5rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #3b82f6;
    border: 1px solid #3b82f6;
    padding: 0.0625rem 0.25rem;
    letter-spacing: 0.05em;
  }

  .dossier-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 0.125rem;
  }

  .dossier-review-star-{{ ai_gen_id }} {
    width: 0.875rem;
    height: 0.875rem;
    fill: #fbbf24;
  }

  .dossier-review-star-{{ ai_gen_id }}.empty {
    fill: #e5e7eb;
  }

  .dossier-review-date-{{ ai_gen_id }} {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .dossier-review-item-title-{{ ai_gen_id }} {
    font-size: 0.875rem;
    font-weight: 700;
    color: #000;
    margin: 0 0 0.5rem 0;
  }

  .dossier-review-item-text-{{ ai_gen_id }} {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  .dossier-review-response-{{ ai_gen_id }} {
    background: #f9fafb;
    padding: 1rem;
    border-radius: 0.125rem;
  }

  .dossier-review-response-label-{{ ai_gen_id }} {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
    color: #000;
  }

  .dossier-review-response-text-{{ ai_gen_id }} {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0;
  }

  .dossier-reviews-cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 2rem;
  }

  .dossier-reviews-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 0.75rem 3rem;
    border: 1px solid #000;
    background: #fff;
    color: #000;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    font-family: 'Inter', sans-serif;
  }

  .dossier-reviews-cta-button-{{ ai_gen_id }}:hover {
    background: #000;
    color: #fff;
  }

  @media screen and (max-width: 749px) {
    .dossier-rating-large-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .dossier-reviews-tabs-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .dossier-review-item-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
{% endstyle %}

<reviews-section-{{ ai_gen_id }} class="dossier-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <h2 class="dossier-reviews-title">{{ block.settings.section_title }}</h2>
  {% endif %}

  <div class="dossier-reviews-layout-{{ ai_gen_id }}">
    <!-- Left Sidebar: Rating Summary -->
    <div class="dossier-reviews-sidebar-{{ ai_gen_id }}">
      <div class="dossier-rating-large-{{ ai_gen_id }}">
        <div class="dossier-rating-number-{{ ai_gen_id }}">{{ block.settings.average_rating }}</div>
        <div>
          <div class="dossier-rating-stars-{{ ai_gen_id }}">
            {% assign full_stars = block.settings.average_rating | floor %}
            {% for i in (1..5) %}
              {% if i <= full_stars %}
                <svg class="dossier-rating-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {% else %}
                <svg class="dossier-rating-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>
          <div class="dossier-rating-label-{{ ai_gen_id }}">Based on {{ block.settings.review_count }} reviews</div>
        </div>
      </div>

      <!-- Rating Distribution Bars -->
      <div class="dossier-rating-bars-{{ ai_gen_id }}">
        {% assign bar_values = block.settings.rating_bar_5 | append: ',' | append: block.settings.rating_bar_4 | append: ',' | append: block.settings.rating_bar_3 | append: ',' | append: block.settings.rating_bar_2 | append: ',' | append: block.settings.rating_bar_1 | split: ',' %}
        {% assign bar_labels = "5,4,3,2,1" | split: ',' %}
        {% for label in bar_labels %}
          {% assign bar_value = bar_values[forloop.index0] | plus: 0 %}
          <div class="dossier-rating-bar-row-{{ ai_gen_id }}">
            <span class="dossier-rating-bar-label-{{ ai_gen_id }}">{{ label }}</span>
            <span>★</span>
            <div class="dossier-rating-bar-track-{{ ai_gen_id }}">
              <div class="dossier-rating-bar-fill-{{ ai_gen_id }}" style="width: {{ bar_value }}%"></div>
            </div>
            <span class="dossier-rating-bar-count-{{ ai_gen_id }}">{{ bar_value | divided_by: 100 | times: block.settings.review_count | remove: '.' | truncate: 5, '' }}</span>
          </div>
        {% endfor %}
      </div>

      <button class="dossier-write-review-btn-{{ ai_gen_id }}">Write a Review</button>
    </div>

    <!-- Right Main: Reviews List -->
    <div class="dossier-reviews-main-{{ ai_gen_id }}">
      <div class="dossier-reviews-tabs-{{ ai_gen_id }}">
        <div class="dossier-reviews-tab-group-{{ ai_gen_id }}">
          <button class="dossier-reviews-tab-{{ ai_gen_id }}">Reviews ({{ block.settings.review_count }})</button>
          <button class="dossier-reviews-tab-{{ ai_gen_id }} inactive">Questions (10)</button>
        </div>
        <div class="dossier-reviews-sort-{{ ai_gen_id }}">
          <span>Sort:</span>
          <select class="dossier-reviews-sort-select-{{ ai_gen_id }}">
            <option>Highest Rating</option>
            <option>Most Recent</option>
          </select>
        </div>
      </div>

      <div class="dossier-reviews-list-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign review_rating_key = 'review_' | append: i | append: '_rating'
            assign review_title_key = 'review_' | append: i | append: '_title'
            assign review_text_key = 'review_' | append: i | append: '_text'
            assign review_author_key = 'review_' | append: i | append: '_author'
            assign review_date_key = 'review_' | append: i | append: '_date'
            assign review_verified_key = 'review_' | append: i | append: '_verified'
            assign review_response_key = 'review_' | append: i | append: '_response'

            assign review_rating = block.settings[review_rating_key]
            assign review_title = block.settings[review_title_key]
            assign review_text = block.settings[review_text_key]
            assign review_author = block.settings[review_author_key]
            assign review_date = block.settings[review_date_key]
            assign review_verified = block.settings[review_verified_key]
            assign review_response = block.settings[review_response_key]

            assign initials = review_author | split: ' ' | first | slice: 0 | upcase
            if review_author contains ' '
              assign last_initial = review_author | split: ' ' | last | slice: 0 | upcase
              assign initials = initials | append: last_initial
            endif
          %}

          <div class="dossier-review-item-{{ ai_gen_id }}">
            <div class="dossier-review-item-header-{{ ai_gen_id }}">
              <div class="dossier-review-author-block-{{ ai_gen_id }}">
                <div class="dossier-review-avatar-{{ ai_gen_id }}">{{ initials }}</div>
                <div class="dossier-review-author-info-{{ ai_gen_id }}">
                  <div class="dossier-review-author-name-{{ ai_gen_id }}">
                    {{ review_author }}
                    {% if review_verified %}
                      <span class="verified-badge">Verified Buyer</span>
                    {% endif %}
                  </div>
                  <div class="dossier-review-stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      {% if star <= review_rating %}
                        <svg class="dossier-review-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                          <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                        </svg>
                      {% else %}
                        <svg class="dossier-review-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                          <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                        </svg>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
              <div class="dossier-review-date-{{ ai_gen_id }}">{{ review_date }}</div>
            </div>

            {% if review_title != blank %}
              <h4 class="dossier-review-item-title-{{ ai_gen_id }}">{{ review_title }}</h4>
            {% endif %}

            {% if review_text != blank %}
              <p class="dossier-review-item-text-{{ ai_gen_id }}">{{ review_text }}</p>
            {% endif %}

            {% if review_response != blank %}
              <div class="dossier-review-response-{{ ai_gen_id }}">
                <p class="dossier-review-response-label-{{ ai_gen_id }}">{{ block.settings.brand_name | default: 'Wildfyre' }} Perfumes</p>
                <p class="dossier-review-response-text-{{ ai_gen_id }}">{{ review_response }}</p>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if block.settings.show_cta_button %}
        <div class="dossier-reviews-cta-{{ ai_gen_id }}">
          <a href="{{ block.settings.button_link }}" class="dossier-reviews-cta-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</reviews-section-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Dossier Reviews",
  "settings": [
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Rating summary"
    },
    {
      "type": "range",
      "id": "average_rating",
      "label": "Average rating",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 4.8
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Total review count",
      "default": "13,299"
    },
    {
      "type": "inline_richtext",
