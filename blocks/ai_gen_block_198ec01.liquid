{% doc %}
  @prompt
    create a review section just like the dossier website we want same ui like that website https://dossier.co/products/ambery-saffron?Size=100ml this is the link, these are having cards we need a section like things
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap');

  .dossier-reviews-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    font-family: 'Inter', sans-serif;
    color: #000;
  }

  .dossier-reviews-{{ ai_gen_id }} .dossier-reviews-title {
    font-family: 'EB Garamond', serif;
    font-size: {{ block.settings.title_size | plus: 16 }}px;
    font-weight: 600;
    margin: 0 0 3rem 0;
    line-height: 1.2;
    color: #000;
    letter-spacing: -0.02em;
  }

  @media screen and (max-width: 749px) {
    .dossier-reviews-{{ ai_gen_id }} .dossier-reviews-title {
      font-size: {{ block.settings.title_size | plus: 8 }}px;
    }
  }

  .dossier-reviews-layout-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media screen and (min-width: 990px) {
    .dossier-reviews-layout-{{ ai_gen_id }} {
      flex-direction: row;
      gap: 6rem;
    }
  }

  .dossier-reviews-sidebar-{{ ai_gen_id }} {
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .dossier-reviews-sidebar-{{ ai_gen_id }} {
      width: 33.333%;
      flex-shrink: 0;
    }
  }

  .dossier-reviews-main-{{ ai_gen_id }} {
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .dossier-reviews-main-{{ ai_gen_id }} {
      width: 66.666%;
    }
  }

  .dossier-rating-large-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .dossier-rating-number-{{ ai_gen_id }} {
    font-family: 'EB Garamond', serif;
    font-size: 6rem;
    font-weight: 600;
    line-height: 1;
    color: #000;
    letter-spacing: -0.03em;
  }

  @media screen and (max-width: 749px) {
    .dossier-rating-number-{{ ai_gen_id }} {
      font-size: 4rem;
    }
  }

  .dossier-rating-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
  }

  .dossier-rating-star-{{ ai_gen_id }} {
    width: 1.75rem;
    height: 1.75rem;
    fill: #f59e0b;
  }

  .dossier-rating-star-{{ ai_gen_id }}.empty {
    fill: #e5e7eb;
  }

  .dossier-rating-label-{{ ai_gen_id }} {
    font-size: 1.125rem;
    color: #6b7280;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .dossier-rating-bars-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-bottom: 2.5rem;
  }

  .dossier-rating-bar-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
  }

  .dossier-rating-bar-label-{{ ai_gen_id }} {
    width: 1.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: #000;
  }

  .dossier-rating-bar-track-{{ ai_gen_id }} {
    flex: 1;
    height: 0.75rem;
    background: #f3f4f6;
    border-radius: 9999px;
    overflow: hidden;
  }

  .dossier-rating-bar-fill-{{ ai_gen_id }} {
    height: 100%;
    background: #000;
    border-radius: 9999px;
    transition: width 0.6s ease;
  }

  .dossier-rating-bar-count-{{ ai_gen_id }} {
    width: 4rem;
    text-align: right;
    font-size: 0.9375rem;
    color: #9ca3af;
  }

  .dossier-write-review-btn-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 1rem 1.5rem;
    background: #fff;
    color: #000;
    border: 2px solid #000;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: all 0.25s ease;
    text-align: center;
    font-family: 'Inter', sans-serif;
  }

  .dossier-write-review-btn-{{ ai_gen_id }}:hover {
    background: #000;
    color: #fff;
  }

  .dossier-reviews-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 0;
  }

  .dossier-reviews-tab-group-{{ ai_gen_id }} {
    display: flex;
    gap: 1.5rem;
  }

  .dossier-reviews-tab-{{ ai_gen_id }} {
    font-size: 1.125rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
    background: none;
    border: none;
    cursor: pointer;
    color: #000;
    padding: 0;
    font-family: 'Inter', sans-serif;
  }

  .dossier-reviews-tab-{{ ai_gen_id }}.inactive {
    color: #9ca3af;
    text-decoration: none;
    font-weight: 400;
  }

  .dossier-reviews-tab-{{ ai_gen_id }}.inactive:hover {
    color: #6b7280;
  }

  .dossier-reviews-sort-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: #6b7280;
  }

  .dossier-reviews-sort-select-{{ ai_gen_id }} {
    border: none;
    background: transparent;
    font-weight: 700;
    color: #000;
    cursor: pointer;
    font-size: 0.9375rem;
    font-family: 'Inter', sans-serif;
    padding: 0;
  }

  .dossier-reviews-sort-select-{{ ai_gen_id }}:focus {
    outline: none;
  }

  .dossier-reviews-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .dossier-review-item-{{ ai_gen_id }} {
    padding: 3rem 0;
    border-bottom: 1px solid #f3f4f6;
    transition: background 0.2s ease;
  }

  .dossier-review-item-{{ ai_gen_id }}:hover {
    background: #fafafa;
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .dossier-review-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .dossier-review-item-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .dossier-review-author-block-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .dossier-review-avatar-{{ ai_gen_id }} {
    width: 3.5rem;
    height: 3.5rem;
    background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #4b5563;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .dossier-review-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .dossier-review-author-name-{{ ai_gen_id }} {
    font-size: 1.125rem;
    font-weight: 700;
    color: #000;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .dossier-review-author-name-{{ ai_gen_id }} .verified-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #2563eb;
    border: 1.5px solid #2563eb;
    padding: 0.125rem 0.4375rem;
    letter-spacing: 0.05em;
    border-radius: 2px;
    display: inline-block;
  }

  .dossier-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 0.1875rem;
  }

  .dossier-review-star-{{ ai_gen_id }} {
    width: 1.125rem;
    height: 1.125rem;
    fill: #f59e0b;
  }

  .dossier-review-star-{{ ai_gen_id }}.empty {
    fill: #e5e7eb;
  }

  .dossier-review-date-{{ ai_gen_id }} {
    font-size: 0.875rem;
    color: #9ca3af;
    white-space: nowrap;
  }

  .dossier-review-item-title-{{ ai_gen_id }} {
    font-size: 1.125rem;
    font-weight: 700;
    color: #000;
    margin: 0 0 0.625rem 0;
    line-height: 1.4;
  }

  .dossier-review-item-text-{{ ai_gen_id }} {
    font-size: 1.0625rem;
    color: #4b5563;
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
    max-width: 90%;
  }

  @media screen and (max-width: 749px) {
    .dossier-review-item-text-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }

  .dossier-review-response-{{ ai_gen_id }} {
    background: #f9fafb;
    padding: 1.5rem;
    border-radius: 4px;
    border-left: 3px solid #d1d5db;
  }

  .dossier-review-response-label-{{ ai_gen_id }} {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    color: #000;
  }

  .dossier-review-response-text-{{ ai_gen_id }} {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.7;
  }

  .dossier-reviews-cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 3rem;
  }

  .dossier-reviews-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 1rem 4rem;
    border: 2px solid #000;
    background: #fff;
    color: #000;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
  }

  .dossier-reviews-cta-button-{{ ai_gen_id }}:hover {
    background: #000;
    color: #fff;
  }

  .dossier-review-hidden-{{ ai_gen_id }} {
    display: none;
  }

  /* ===== QUESTIONS TAB UI ===== */
  .dossier-questions-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .dossier-question-item-{{ ai_gen_id }} {
    padding: 3rem 0;
    border-bottom: 1px solid #f3f4f6;
    transition: background 0.2s ease;
  }

  .dossier-question-item-{{ ai_gen_id }}:hover {
    background: #fafafa;
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .dossier-question-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .dossier-question-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .dossier-question-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .dossier-question-avatar-{{ ai_gen_id }} {
    width: 2.75rem;
    height: 2.75rem;
    background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    color: #4b5563;
    flex-shrink: 0;
  }

  .dossier-question-name-{{ ai_gen_id }} {
    font-size: 1rem;
    font-weight: 700;
    color: #000;
  }

  .dossier-question-date-{{ ai_gen_id }} {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .dossier-question-text-{{ ai_gen_id }} {
    font-size: 1.0625rem;
    color: #374151;
    line-height: 1.7;
    margin: 0 0 1rem 0;
    max-width: 90%;
  }

  .dossier-question-answer-{{ ai_gen_id }} {
    background: #f9fafb;
    padding: 1.5rem;
    border-radius: 4px;
    border-left: 3px solid #000;
  }

  .dossier-question-answer-label-{{ ai_gen_id }} {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    color: #000;
  }

  .dossier-question-answer-text-{{ ai_gen_id }} {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.7;
  }

  .dossier-ask-question-btn-{{ ai_gen_id }} {
    display: inline-block;
    padding: 1rem 3rem;
    border: 2px solid #000;
    background: #fff;
    color: #000;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
    margin-top: 2rem;
    text-align: center;
  }

  .dossier-ask-question-btn-{{ ai_gen_id }}:hover {
    background: #000;
    color: #fff;
  }

  /* ===== WRITE REVIEW MODAL ===== */
  .dossier-review-modal-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
  }

  .dossier-review-modal-overlay-{{ ai_gen_id }}.active {
    display: flex;
  }

  .dossier-review-modal-{{ ai_gen_id }} {
    background: #fff;
    max-width: 560px;
    width: 100%;
    padding: 3rem;
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
  }

  .dossier-review-modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #9ca3af;
    padding: 0.5rem;
    line-height: 1;
  }

  .dossier-review-modal-close-{{ ai_gen_id }}:hover {
    color: #000;
  }

  .dossier-review-modal-title-{{ ai_gen_id }} {
    font-family: 'EB Garamond', serif;
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  .dossier-review-modal-subtitle-{{ ai_gen_id }} {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 2rem 0;
  }

  .dossier-review-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .dossier-review-form-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dossier-review-form-label-{{ ai_gen_id }} {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #000;
  }

  .dossier-review-form-input-{{ ai_gen_id }},
  .dossier-review-form-textarea-{{ ai_gen_id }} {
    padding: 0.875rem 1rem;
    border: 1.5px solid #d1d5db;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    transition: border-color 0.2s ease;
    background: #fff;
    color: #000;
    width: 100%;
    box-sizing: border-box;
  }

  .dossier-review-form-input-{{ ai_gen_id }}:focus,
  .dossier-review-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: #000;
  }

  .dossier-review-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .dossier-review-form-rating-{{ ai_gen_id }} {
    display: flex;
    gap: 0.5rem;
    direction: rtl;
  }

  .dossier-review-form-rating-{{ ai_gen_id }} input {
    display: none;
  }

  .dossier-review-form-rating-{{ ai_gen_id }} label {
    font-size: 2rem;
    cursor: pointer;
    color: #e5e7eb;
    transition: color 0.15s ease;
    direction: ltr;
  }

  .dossier-review-form-rating-{{ ai_gen_id }} label:hover,
  .dossier-review-form-rating-{{ ai_gen_id }} label:hover ~ label,
  .dossier-review-form-rating-{{ ai_gen_id }} input:checked ~ label {
    color: #f59e0b;
  }

  .dossier-review-form-submit-{{ ai_gen_id }} {
    padding: 1rem 2rem;
    background: #000;
    color: #fff;
    border: none;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
    margin-top: 0.5rem;
  }

  .dossier-review-form-submit-{{ ai_gen_id }}:hover {
    background: #333;
  }

  .dossier-review-form-success-{{ ai_gen_id }} {
    text-align: center;
    padding: 3rem 1rem;
    display: none;
  }

  .dossier-review-form-success-{{ ai_gen_id }}.active {
    display: block;
  }

  .dossier-review-form-success-icon-{{ ai_gen_id }} {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .dossier-review-form-success-title-{{ ai_gen_id }} {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .dossier-review-form-success-text-{{ ai_gen_id }} {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .dossier-rating-large-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .dossier-reviews-tabs-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .dossier-review-item-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .dossier-review-modal-{{ ai_gen_id }} {
      padding: 2rem 1.5rem;
    }
  }
{% endstyle %}

<reviews-section-{{ ai_gen_id }} class="dossier-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <h2 class="dossier-reviews-title">{{ block.settings.section_title }}</h2>
  {% endif %}

  {% comment %}
    ==========================================
    COMPUTED VALUES
    ==========================================
  {% endcomment %}
  {% liquid
    assign review_count_raw = block.settings.total_review_count | remove: ',' | remove: '.' | plus: 0
    if review_count_raw == 0
      assign review_count_raw = 13299
    endif
    assign total_reviews = review_count_raw

    assign display_count = block.settings.initial_review_count | plus: 0
    if display_count == 0
      assign display_count = 3
    endif

    assign bar_5 = block.settings.rating_bar_5 | plus: 0
    assign bar_4 = block.settings.rating_bar_4 | plus: 0
    assign bar_3 = block.settings.rating_bar_3 | plus: 0
    assign bar_2 = block.settings.rating_bar_2 | plus: 0
    assign bar_1 = block.settings.rating_bar_1 | plus: 0

    assign count_5 = total_reviews | times: bar_5 | divided_by: 100
    assign count_4 = total_reviews | times: bar_4 | divided_by: 100
    assign count_3 = total_reviews | times: bar_3 | divided_by: 100
    assign count_2 = total_reviews | times: bar_2 | divided_by: 100
    assign count_1 = total_reviews | times: bar_1 | divided_by: 100

    assign question_count = block.settings.question_count | plus: 0
    if question_count == 0
      assign question_count = 3
    endif
  %}

  {% capture formatted_total %}{{ total_reviews }}{% endcapture %}
  {% assign formatted_total = total_reviews %}

  <div class="dossier-reviews-layout-{{ ai_gen_id }}">
    <!-- Left Sidebar: Rating Summary -->
    <div class="dossier-reviews-sidebar-{{ ai_gen_id }}">
      <div class="dossier-rating-large-{{ ai_gen_id }}">
        <div class="dossier-rating-number-{{ ai_gen_id }}">{{ block.settings.average_rating }}</div>
        <div>
          <div class="dossier-rating-stars-{{ ai_gen_id }}">
            {% assign full_stars = block.settings.average_rating | floor %}
            {% for i in (1..5) %}
              {% if i <= full_stars %}
                <svg class="dossier-rating-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {% else %}
                <svg class="dossier-rating-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>
          <div class="dossier-rating-label-{{ ai_gen_id }}">Based on {{ formatted_total | default: '13,299' }} reviews</div>
        </div>
      </div>

      <!-- Rating Distribution Bars -->
      <div class="dossier-rating-bars-{{ ai_gen_id }}">
        {% assign bar_percentages = "5,4,3,2,1" | split: ',' %}
        {% assign bar_counts = count_5 | append: ',' | append: count_4 | append: ',' | append: count_3 | append: ',' | append: count_2 | append: ',' | append: count_1 | split: ',' %}
        {% for label in bar_percentages %}
          {% assign bar_pct = block.settings['rating_bar_' | append: label] | plus: 0 %}
          {% assign bar_cnt = bar_counts[forloop.index0] | plus: 0 %}
          <div class="dossier-rating-bar-row-{{ ai_gen_id }}">
            <span class="dossier-rating-bar-label-{{ ai_gen_id }}">{{ label }}</span>
            <span>★</span>
            <div class="dossier-rating-bar-track-{{ ai_gen_id }}">
              <div class="dossier-rating-bar-fill-{{ ai_gen_id }}" style="width: {{ bar_pct }}%"></div>
            </div>
            <span class="dossier-rating-bar-count-{{ ai_gen_id }}">{{ bar_cnt }}</span>
          </div>
        {% endfor %}
      </div>

      <button class="dossier-write-review-btn-{{ ai_gen_id }}" data-open-modal="{{ ai_gen_id }}">Write a Review</button>
    </div>

    <!-- Right Main: Reviews / Questions Tabs -->
    <div class="dossier-reviews-main-{{ ai_gen_id }}" data-reviews-section="{{ ai_gen_id }}">
      <div class="dossier-reviews-tabs-{{ ai_gen_id }}">
        <div class="dossier-reviews-tab-group-{{ ai_gen_id }}">
          <button class="dossier-reviews-tab-{{ ai_gen_id }}" data-tab="reviews" data-tab-group="{{ ai_gen_id }}">Reviews ({{ formatted_total }})</button>
          <button class="dossier-reviews-tab-{{ ai_gen_id }} inactive" data-tab="questions" data-tab-group="{{ ai_gen_id }}">Questions ({{ question_count }})</button>
        </div>
        <div class="dossier-reviews-sort-{{ ai_gen_id }}" data-sort-container>
          <span>Sort:</span>
          <select class="dossier-reviews-sort-select-{{ ai_gen_id }}" data-sort-select>
            <option value="highest">Highest Rating</option>
            <option value="recent" selected>Most Recent</option>
          </select>
        </div>
      </div>

      <!-- ===== REVIEWS TAB CONTENT ===== -->
      <div data-tab-content="reviews" data-tab-group="{{ ai_gen_id }}">
        <div class="dossier-reviews-list-{{ ai_gen_id }}" data-reviews-list>
          {% assign review_total = block.settings.review_count | plus: 0 %}
          {% if review_total == 0 %}
            {% assign review_total = 6 %}
          {% endif %}

          {% for i in (1..review_total) %}
            {% liquid
              assign review_rating_key = 'review_' | append: i | append: '_rating'
              assign review_title_key = 'review_' | append: i | append: '_title'
              assign review_text_key = 'review_' | append: i | append: '_text'
              assign review_author_key = 'review_' | append: i | append: '_author'
              assign review_date_key = 'review_' | append: i | append: '_date'
              assign review_verified_key = 'review_' | append: i | append: '_verified'
              assign review_response_key = 'review_' | append: i | append: '_response'

              assign review_rating = block.settings[review_rating_key]
              assign review_title = block.settings[review_title_key]
              assign review_text = block.settings[review_text_key]
              assign review_author = block.settings[review_author_key] | default: 'Anonymous'
              assign review_date = block.settings[review_date_key]
              assign review_verified = block.settings[review_verified_key]
              assign review_response = block.settings[review_response_key]

              assign initials = review_author | split: ' ' | first | slice: 0 | upcase
              if review_author contains ' '
                assign last_initial = review_author | split: ' ' | last | slice: 0 | upcase
                assign initials = initials | append: last_initial
              endif

              assign is_hidden = false
              if i > display_count
                assign is_hidden = true
              endif
            %}

            {% if review_text != blank or review_title != blank %}
              <div class="dossier-review-item-{{ ai_gen_id }} {% if is_hidden %}dossier-review-hidden-{{ ai_gen_id }}{% endif %}" 
                   data-review-rating="{{ review_rating }}"
                   data-review-date="{{ review_date | date: '%s' | default: forloop.index }}"
                   data-review-index="{{ i }}">
                <div class="dossier-review-item-header-{{ ai_gen_id }}">
                  <div class="dossier-review-author-block-{{ ai_gen_id }}">
                    <div class="dossier-review-avatar-{{ ai_gen_id }}">{{ initials }}</div>
                    <div class="dossier-review-author-info-{{ ai_gen_id }}">
                      <div class="dossier-review-author-name-{{ ai_gen_id }}">
                        {{ review_author }}
                        {% if review_verified %}
                          <span class="verified-badge">Verified Buyer</span>
                        {% endif %}
                      </div>
                      <div class="dossier-review-stars-{{ ai_gen_id }}">
                        {% for star in (1..5) %}
                          {% if star <= review_rating %}
                            <svg class="dossier-review-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                              <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                            </svg>
                          {% else %}
                            <svg class="dossier-review-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                              <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                            </svg>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                  <div class="dossier-review-date-{{ ai_gen_id }}">{{ review_date }}</div>
                </div>

                {% if review_title != blank %}
                  <h4 class="dossier-review-item-title-{{ ai_gen_id }}">{{ review_title }}</h4>
                {% endif %}

                {% if review_text != blank %}
                  <p class="dossier-review-item-text-{{ ai_gen_id }}">{{ review_text }}</p>
                {% endif %}

                {% if review_response != blank %}
                  <div class="dossier-review-response-{{ ai_gen_id }}">
                    <p class="dossier-review-response-label-{{ ai_gen_id }}">{{ block.settings.brand_name | default: 'Wildfyre' }} Perfumes</p>
                    <p class="dossier-review-response-text-{{ ai_gen_id }}">{{ review_response }}</p>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {% if review_total > display_count %}
          <div class="dossier-reviews-cta-{{ ai_gen_id }}">
            <button class="dossier-reviews-cta-button-{{ ai_gen_id }}" data-show-more="{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </button>
          </div>
        {% endif %}
      </div>

      <!-- ===== QUESTIONS TAB CONTENT ===== -->
      <div data-tab-content="questions" data-tab-group="{{ ai_gen_id }}" style="display: none;">
        <div class="dossier-questions-list-{{ ai_gen_id }}" data-questions-list>
          {% for i in (1..question_count) %}
            {% liquid
              assign question_author_key = 'question_' | append: i | append: '_author'
              assign question_text_key = 'question_' | append: i | append: '_text'
              assign question_date_key = 'question_' | append: i | append: '_date'
              assign question_answer_key = 'question_' | append: i | append: '_answer'

              assign q_author = block.settings[question_author_key] | default: 'Anonymous'
              assign q_text = block.settings[question_text_key]
              assign q_date = block.settings[question_date_key]
              assign q_answer = block.settings[question_answer_key]

              assign q_initials = q_author | split: ' ' | first | slice: 0 | upcase
              if q_author contains ' '
                assign q_last = q_author | split: ' ' | last | slice: 0 | upcase
                assign q_initials = q_initials | append: q_last
              endif
            %}

            {% if q_text != blank %}
              <div class="dossier-question-item-{{ ai_gen_id }}">
                <div class="dossier-question-header-{{ ai_gen_id }}">
                  <div class="dossier-question-author-{{ ai_gen_id }}">
                    <div class="dossier-question-avatar-{{ ai_gen_id }}">{{ q_initials }}</div>
                    <div class="dossier-question-name-{{ ai_gen_id }}">{{ q_author }}</div>
                  </div>
                  <div class="dossier-question-date-{{ ai_gen_id }}">{{ q_date }}</div>
                </div>
                <p class="dossier-question-text-{{ ai_gen_id }}">{{ q_text }}</p>
                {% if q_answer != blank %}
                  <div class="dossier-question-answer-{{ ai_gen_id }}">
                    <p class="dossier-question-answer-label-{{ ai_gen_id }}">{{ block.settings.brand_name | default: 'Wildfyre' }} Perfumes</p>
                    <p class="dossier-question-answer-text-{{ ai_gen_id }}">{{ q_answer }}</p>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <button class="dossier-ask-question-btn-{{ ai_gen_id }}" data-ask-question="{{ ai_gen_id }}">Ask a Question</button>
      </div>
    </div>
  </div>
</reviews-section-{{ ai_gen_id }}>

<!-- ===== WRITE REVIEW MODAL ===== -->
<div class="dossier-review-modal-overlay-{{ ai_gen_id }}" data-modal-overlay="{{ ai_gen_id }}">
  <div class="dossier-review-modal-{{ ai_gen_id }}">
    <button class="dossier-review-modal-close-{{ ai_gen_id }}" data-modal-close="{{ ai_gen_id }}">✕</button>

    <div class="dossier-review-modal-form-{{ ai_gen_id }}" data-modal-form-container>
      <h3 class="dossier-review-modal-title-{{ ai_gen_id }}">Write a Review</h3>
      <p class="dossier-review-modal-subtitle-{{ ai_gen_id }}">Share your thoughts with others</p>

      <form class="dossier-review-form-{{ ai_gen_id }}" data-review-form="{{ ai_gen_id }}">
        <div class="dossier-review-form-group-{{ ai_gen_id }}">
          <label class="dossier-review-form-label-{{ ai_gen_id }}" for="review-name-{{ ai_gen_id }}">Your Name *</label>
          <input class="dossier-review-form-input-{{ ai_gen_id }}" type="text" id="review-name-{{ ai_gen_id }}" name="name" required placeholder="Enter your name">
        </div>

        <div class="dossier-review-form-group-{{ ai_gen_id }}">
          <label class="dossier-review-form-label-{{ ai_gen_id }}">Your Rating *</label>
          <div class="dossier-review-form-rating-{{ ai_gen_id }}" data-star-rating>
            <input type="radio" id="star5-{{ ai_gen_id }}" name="rating" value="5">
            <label for="star5-{{ ai_gen_id }}" title="5 stars">★</label>
            <input type="radio" id="star4-{{ ai_gen_id }}" name="rating" value="4">
            <label for="star4-{{ ai_gen_id }}" title="4 stars">★</label>
            <input type="radio" id="star3-{{ ai_gen_id }}" name="rating" value="3">
            <label for="star3-{{ ai_gen_id }}" title="3 stars">★</label>
            <input type="radio" id="star2-{{ ai_gen_id }}" name="rating" value="2">
            <label for="star2-{{ ai_gen_id }}" title="2 stars">★</label>
            <input type="radio" id="star1-{{ ai_gen_id }}" name="rating" value="1" checked>
            <label for="star1-{{ ai_gen_id }}" title="1 star">★</label>
          </div>
        </div>

        <div class="dossier-review-form-group-{{ ai_gen_id }}">
          <label class="dossier-review-form-label-{{ ai_gen_id }}" for="review-title-{{ ai_gen_id }}">Review Title</label>
          <input class="dossier-review-form-input-{{ ai_gen_id }}" type="text" id="review-title-{{ ai_gen_id }}" name="title" placeholder="Summarize your review">
        </div>

        <div class="dossier-review-form-group-{{ ai_gen_id }}">
          <label class="dossier-review-form-label-{{ ai_gen_id }}" for="review-text-{{ ai_gen_id }}">Your Review *</label>
          <textarea class="dossier-review-form-textarea-{{ ai_gen_id }}" id="review-text-{{ ai_gen_id }}" name="text" required placeholder="Tell others about your experience..."></textarea>
        </div>

        <button class="dossier-review-form-submit-{{ ai_gen_id }}" type="submit">Submit Review</button>
      </form>
    </div>

    <div class="dossier-review-form-success-{{ ai_gen_id }}" data-modal-success>
      <div class="dossier-review-form-success-icon-{{ ai_gen_id }}">✓</div>
      <h3 class="dossier-review-form-success-title-{{ ai_gen_id }}">Thank You!</h3>
      <p class="dossier-review-form-success-text-{{ ai_gen_id }}">Your review has been submitted and will appear after moderation.</p>
    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ ai_gen_id }}';
    const section = document.querySelector(`[data-reviews-section="${sectionId}"]`);
    if (!section) return;

    // ===== DOM REFS =====
    const reviewsList = section.querySelector('[data-reviews-list]');
    const sortSelect = section.querySelector('[data-sort-select]');
    const showMoreBtn = section.querySelector('[data-show-more]');
    const tabs = section.querySelectorAll('[data-tab]');
    const tabGroup = sectionId;

    // Modal refs
    const modalOverlay = document.querySelector(`[data-modal-overlay="${sectionId}"]`);
    const modalClose = document.querySelector(`[data-modal-close="${sectionId}"]`);
    const openModalBtn = document.querySelector(`[data-open-modal="${sectionId}"]`);
    const reviewForm = document.querySelector(`[data-review-form="${sectionId}"]`);
    const modalFormContainer = modalOverlay ? modalOverlay.querySelector('[data-modal-form-container]') : null;
    const modalSuccess = modalOverlay ? modalOverlay.querySelector('[data-modal-success]') : null;

    // ===== TAB SWITCHING =====
    function switchTab(tabName) {
      // Update tab button states
      tabs.forEach(t => {
        const isActive = t.dataset.tab === tabName;
        if (isActive) {
          t.classList.remove('inactive');
        } else {
          t.classList.add('inactive');
        }
      });

      // Show/hide tab content
      const contents = document.querySelectorAll(`[data-tab-content][data-tab-group="${tabGroup}"]`);
      contents.forEach(content => {
        if (content.dataset.tabContent === tabName) {
          content.style.display = 'block';
        } else {
          content.style.display = 'none';
        }
      });

      // Show/hide sort dropdown (only for reviews tab)
      const sortContainer = section.querySelector('[data-sort-container]');
      if (sortContainer) {
        sortContainer.style.display = tabName === 'reviews' ? 'flex' : 'none';
      }
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        switchTab(this.dataset.tab);
      });
    });

    // ===== SORT FUNCTIONALITY =====
    function getReviewItems() {
      return Array.from(reviewsList.querySelectorAll('[data-review-rating]'));
    }

    function sortReviews(criteria) {
      const items = getReviewItems();
      const parent = reviewsList;
      
      items.forEach(item => item.remove());

      const sorted = items.sort((a, b) => {
        if (criteria === 'highest') {
          const ratingA = parseInt(a.dataset.reviewRating) || 0;
          const ratingB = parseInt(b.dataset.reviewRating) || 0;
          if (ratingB !== ratingA) return ratingB - ratingA;
          return (parseInt(b.dataset.reviewIndex) || 0) - (parseInt(a.dataset.reviewIndex) || 0);
        } else if (criteria === 'recent') {
          return (parseInt(b.dataset.reviewIndex) || 0) - (parseInt(a.dataset.reviewIndex) || 0);
        }
        return 0;
      });

      sorted.forEach(item => parent.appendChild(item));

      const showAll = showMoreBtn && showMoreBtn.dataset.expanded === 'true';
      applyVisibility(sorted, showAll);
    }

    // ===== SHOW MORE / SEE ALL =====
    function applyVisibility(items, showAll) {
      const displayCount = parseInt('{{ display_count }}') || 3;
      items.forEach((item, index) => {
        if (showAll || index < displayCount) {
          item.classList.remove('dossier-review-hidden-{{ ai_gen_id }}');
        } else {
          item.classList.add('dossier-review-hidden-{{ ai_gen_id }}');
        }
      });
    }

    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', function() {
        const isExpanded = this.dataset.expanded === 'true';
        const items = getReviewItems();
        
        if (!isExpanded) {
          applyVisibility(items, true);
          this.dataset.expanded = 'true';
          this.textContent = 'Show Less';
        } else {
          applyVisibility(items, false);
          this.dataset.expanded = 'false';
          this.textContent = '{{ block.settings.button_text }}';
        }
      });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        sortReviews(this.value);
      });
    }

    // ===== WRITE REVIEW MODAL =====
    if (openModalBtn && modalOverlay) {
      openModalBtn.addEventListener('click', function() {
        modalOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    }

    function closeModal() {
      if (modalOverlay) {
        modalOverlay.classList.remove('active');
        document.body.style.overflow = '';
      }
      // Reset form
      if (reviewForm) {
        reviewForm.reset();
        reviewForm.style.display = '';
      }
      if (modalFormContainer) {
        modalFormContainer.style.display = '';
      }
      if (modalSuccess) {
        modalSuccess.classList.remove('active');
      }
    }

    if (modalClose) {
      modalClose.addEventListener('click', closeModal);
    }

    if (modalOverlay) {
      modalOverlay.addEventListener('click', function(e) {
        if (e.target === this) closeModal();
      });
    }

    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modalOverlay && modalOverlay.classList.contains('active')) {
        closeModal();
      }
    });

    // ===== REVIEW FORM SUBMIT =====
    if (reviewForm) {
      reviewForm.addEventListener('submit', function(e) {
        e.preventDefault();

        const name = this.querySelector('[name="name"]').value.trim();
        const rating = this.querySelector('[name="rating"]:checked')?.value || '5';
        const title = this.querySelector('[name="title"]').value.trim();
        const text = this.querySelector('[name="text"]').value.trim();

        if (!name || !text) {
          alert('Please fill in your name and review text.');
          return;
        }

        // Add the new review to the top of the list
        const currentDate = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        const initials = name.split(' ').map(n => n.charAt(0).toUpperCase()).join('').slice(0, 2);

        const reviewItem = document.createElement('div');
        reviewItem.className = 'dossier-review-item-{{ ai_gen_id }}';
        reviewItem.setAttribute('data-review-rating', rating);
        reviewItem.setAttribute('data-review-date', Math.floor(Date.now() / 1000));
        reviewItem.setAttribute('data-review-index', '999');

        let starsHtml = '';
        for (let s = 1; s <= 5; s++) {
          if (s <= parseInt(rating)) {
            starsHtml += '<svg class="dossier-review-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>';
          } else {
            starsHtml += '<svg class="dossier-review-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>';
          }
        }

        const titleHtml = title ? `<h4 class="dossier-review-item-title-{{ ai_gen_id }}">${title}</h4>` : '';
        const textHtml = text ? `<p class="dossier-review-item-text-{{ ai_gen_id }}">${text}</p>` : '';

        reviewItem.innerHTML = `
          <div class="dossier-review-item-header-{{ ai_gen_id }}">
            <div class="dossier-review-author-block-{{ ai_gen_id }}">
              <div class="dossier-review-avatar-{{ ai_gen_id }}">${initials}</div>
              <div class="dossier-review-author-info-{{ ai_gen_id }}">
                <div class="dossier-review-author-name-{{ ai_gen_id }}">
                  ${name}
                </div>
                <div class="dossier-review-stars-{{ ai_gen_id }}">${starsHtml}</div>
              </div>
            </div>
            <div class="dossier-review-date-{{ ai_gen_id }}">${currentDate}</div>
          </div>
          ${titleHtml}
          ${textHtml}
        `;

        reviewsList.insertBefore(reviewItem, reviewsList.firstChild);

        // Update review count
        const reviewTab = section.querySelector('[data-tab="reviews"]');
        if (reviewTab) {
          const match = reviewTab.textContent.match(/(.*?\()(\d+[,\d]*)(\).*)/);
          if (match) {
            const currentCount = parseInt(match[2].replace(/,/g, '')) || 0;
            reviewTab.textContent = match[1] + (currentCount + 1) + match[3];
          }
        }

        // Show success state
        if (modalFormContainer) modalFormContainer.style.display = 'none';
        if (modalSuccess) modalSuccess.classList.add('active');

        // Close modal after 2.5 seconds
        setTimeout(closeModal, 2500);
      });
    }

    // ===== ASK A QUESTION (placeholder - opens email or alert) =====
    const askBtn = section.querySelector('[data-ask-question]');
    if (askBtn) {
      askBtn.addEventListener('click', function() {
        const brandEmail = '{{ block.settings.brand_email }}';
        if (brandEmail) {
          window.location.href = `mailto:${brandEmail}?subject=Question%20about%20your%20products`;
        } else {
          alert('To ask a question, please contact our support team.');
        }
      });
    }

    // ===== INITIAL STATE =====
    // Default to reviews tab, sort by most recent
    switchTab('reviews');
    sortReviews('recent');
  })();
</script>

