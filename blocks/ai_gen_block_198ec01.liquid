      "info": "Number of reviews visible before clicking Show More"
    },
    {
      "type": "range",
      "id": "review_count",
      "label": "Total review slots",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6,
      "info": "Total number of review slots available in the theme settings"
    },
    {
      "type": "header",
      "content": "Rating Distribution (percentage)"
    },
    {
      "type": "range",
      "id": "rating_bar_5",
      "label": "5★ bar width %",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 92
    },
    {
      "type": "range",
      "id": "rating_bar_4",
