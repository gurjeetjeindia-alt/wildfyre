      "id": "hover_shadow_blur",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 25
    },
    {
      "type": "range",
      "id": "hover_shadow_opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.1
    }
  ],
  "presets": [
    {
      "name": "Product carousel"
    }
  ]
}
{% endschema %}
