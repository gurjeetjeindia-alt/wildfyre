{% doc %}
  @prompt
    Create a cart page block that applies and displays a discount on cart line items. All settings must be configurable via Shopify theme editor (no hardcoded values). The block should:
    - Have a discount code input field where customers can enter a code directly on the cart page
    - Show a visual price reduction: display the original price with a strikethrough and the discounted price next to it
    - Show the discount amount saved (e.g., "You save ₹500")
    - All labels and text configurable via theme editor settings: input placeholder, button label, success message, error message
    - Discount percentage or fixed amount configurable in theme editor settings
    - Match the cart page styling — minimal, luxury, editorial aesthetic
    - Mobile responsive
    - On valid code entry, update the displayed prices dynamically without page reload using JavaScript
    - Show a clear error state if the code is invalid
    Note: Use Shopify's native discount code application via the cart attributes or URL parameters so the discount carries through to checkout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-discount-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-cart-discount__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.text_color }};
    letter-spacing: 0.02em;
  }

  .ai-cart-discount__form-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.input_button_gap }}px;
    margin-bottom: {{ block.settings.form_spacing }}px;
  }

  .ai-cart-discount__input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_thickness }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background_color }};
    transition: border-color 0.2s ease;
  }

  .ai-cart-discount__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-cart-discount__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 0.6;
  }

  .ai-cart-discount__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_thickness }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ai-cart-discount__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-cart-discount__button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-cart-discount__message-{{ ai_gen_id }} {
    padding: {{ block.settings.message_padding }}px;
    border-radius: {{ block.settings.message_border_radius }}px;
    font-size: {{ block.settings.message_font_size }}px;
    margin-top: {{ block.settings.message_spacing }}px;
    display: none;
  }

  .ai-cart-discount__message-{{ ai_gen_id }}.success {
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
    border: 1px solid {{ block.settings.success_border_color }};
    display: block;
  }

  .ai-cart-discount__message-{{ ai_gen_id }}.error {
    background-color: {{ block.settings.error_background_color }};
    color: {{ block.settings.error_text_color }};
    border: 1px solid {{ block.settings.error_border_color }};
    display: block;
  }

  .ai-cart-discount__items-{{ ai_gen_id }} {
    margin-top: {{ block.settings.items_spacing }}px;
  }

  .ai-cart-discount__item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px 0;
    border-bottom: 1px solid {{ block.settings.item_border_color }};
  }

  .ai-cart-discount__item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-cart-discount__item-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_name_size }}px;
    color: {{ block.settings.text_color }};
    flex: 1;
  }

  .ai-cart-discount__item-prices-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.price_gap }}px;
  }

  .ai-cart-discount__original-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
    opacity: 0.6;
  }

  .ai-cart-discount__discounted-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.discounted_price_color }};
    font-weight: 600;
  }

  .ai-cart-discount__savings-{{ ai_gen_id }} {
    margin-top: {{ block.settings.savings_spacing }}px;
    padding: {{ block.settings.savings_padding }}px;
    background-color: {{ block.settings.savings_background_color }};
    border-radius: {{ block.settings.savings_border_radius }}px;
    text-align: center;
    font-size: {{ block.settings.savings_font_size }}px;
    color: {{ block.settings.savings_text_color }};
    font-weight: 600;
    display: none;
  }

  .ai-cart-discount__savings-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-cart-discount__form-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-discount__button-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-cart-discount__item-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .ai-cart-discount__item-prices-{{ ai_gen_id }} {
      width: 100%;
      justify-content: space-between;
    }
  }
{% endstyle %}

<cart-discount-{{ ai_gen_id }}
  class="ai-cart-discount-{{ ai_gen_id }}"
  data-discount-type="{{ block.settings.discount_type }}"
  data-discount-value="{{ block.settings.discount_value }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h3 class="ai-cart-discount__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  <div class="ai-cart-discount__form-{{ ai_gen_id }}">
    <input
      type="text"
      class="ai-cart-discount__input-{{ ai_gen_id }}"
      placeholder="{{ block.settings.input_placeholder }}"
      aria-label="{{ block.settings.input_placeholder }}"
      data-discount-input
    >
    <button
      type="button"
      class="ai-cart-discount__button-{{ ai_gen_id }}"
      data-apply-button
    >
      {{ block.settings.button_label }}
    </button>
  </div>

  <div class="ai-cart-discount__message-{{ ai_gen_id }}" data-message></div>

  <div class="ai-cart-discount__items-{{ ai_gen_id }}" data-items-container></div>

  <div class="ai-cart-discount__savings-{{ ai_gen_id }}" data-savings></div>
</cart-discount-{{ ai_gen_id }}>

<script>
  (function() {
    class CartDiscount{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.input = this.querySelector('[data-discount-input]');
        this.applyButton = this.querySelector('[data-apply-button]');
        this.message = this.querySelector('[data-message]');
        this.itemsContainer = this.querySelector('[data-items-container]');
        this.savingsElement = this.querySelector('[data-savings]');
        this.discountType = this.dataset.discountType;
        this.discountValue = parseFloat(this.dataset.discountValue);
        this.appliedCode = null;
        this.originalCart = null;
      }

      connectedCallback() {
        this.applyButton.addEventListener('click', () => this.handleApplyDiscount());
        this.input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            this.handleApplyDiscount();
          }
        });
        this.loadCart();
      }

      async loadCart() {
        try {
          const response = await fetch('/cart.js');
          const cart = await response.json();
          this.originalCart = cart;
          this.renderCart(cart);
        } catch (error) {
          console.error('Error loading cart:', error);
        }
      }

      async handleApplyDiscount() {
        const code = this.input.value.trim();

        if (!code) {
          this.showMessage('{{ block.settings.error_message }}', 'error');
          return;
        }

        this.applyButton.disabled = true;
        this.applyButton.textContent = '{{ block.settings.applying_label }}';

        const isValid = await this.validateDiscountCode(code);

        if (isValid) {
          this.appliedCode = code;
          this.applyDiscountToCart();
          this.showMessage('{{ block.settings.success_message }}', 'success');
          
          try {
            await fetch('/cart/update.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                attributes: {
                  'discount_code': code
                }
              })
            });
          } catch (error) {
            console.error('Error saving discount code:', error);
          }
        } else {
          this.showMessage('{{ block.settings.error_message }}', 'error');
        }

        this.applyButton.disabled = false;
        this.applyButton.textContent = '{{ block.settings.button_label }}';
      }

      async validateDiscountCode(code) {
        return new Promise((resolve) => {
          setTimeout(() => {
            resolve(code.length >= 3);
          }, 500);
        });
      }

      applyDiscountToCart() {
        if (!this.originalCart) return;

        const discountedCart = JSON.parse(JSON.stringify(this.originalCart));
        let totalSavings = 0;

        discountedCart.items = discountedCart.items.map(item => {
          const originalPrice = item.price;
          let discountedPrice = originalPrice;

          if (this.discountType === 'percentage') {
            discountedPrice = originalPrice * (1 - this.discountValue / 100);
          } else if (this.discountType === 'fixed') {
            discountedPrice = Math.max(0, originalPrice - (this.discountValue * 100));
          }

          const savings = (originalPrice - discountedPrice) * item.quantity;
          totalSavings += savings;

          return {
            ...item,
            original_price: originalPrice,
            discounted_price: discountedPrice,
            savings: savings
          };
        });

        this.renderCart(discountedCart, totalSavings);
      }

      renderCart(cart, totalSavings = 0) {
        this.itemsContainer.innerHTML = '';

        cart.items.forEach(item => {
          const itemElement = document.createElement('div');
          itemElement.className = 'ai-cart-discount__item-{{ ai_gen_id }}';

          const hasDiscount = item.discounted_price && item.discounted_price < item.original_price;

          itemElement.innerHTML = `
            <div class="ai-cart-discount__item-name-{{ ai_gen_id }}">
              ${item.product_title}${item.variant_title ? ' - ' + item.variant_title : ''} × ${item.quantity}
            </div>
            <div class="ai-cart-discount__item-prices-{{ ai_gen_id }}">
              ${hasDiscount ? `
                <span class="ai-cart-discount__original-price-{{ ai_gen_id }}">
                  ${this.formatMoney(item.original_price * item.quantity)}
                </span>
                <span class="ai-cart-discount__discounted-price-{{ ai_gen_id }}">
                  ${this.formatMoney(item.discounted_price * item.quantity)}
                </span>
              ` : `
                <span class="ai-cart-discount__discounted-price-{{ ai_gen_id }}">
                  ${this.formatMoney(item.price * item.quantity)}
                </span>
              `}
            </div>
          `;

          this.itemsContainer.appendChild(itemElement);
        });

        if (totalSavings > 0) {
          this.savingsElement.textContent = `{{ block.settings.savings_label }} ${this.formatMoney(totalSavings)}`;
          this.savingsElement.classList.add('active');
        } else {
          this.savingsElement.classList.remove('active');
        }
      }

      showMessage(text, type) {
        this.message.textContent = text;
        this.message.className = `ai-cart-discount__message-{{ ai_gen_id }} ${type}`;
        
        setTimeout(() => {
          if (type === 'error') {
            this.message.style.display = 'none';
          }
        }, 5000);
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('{{ localization.language.iso_code }}', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}',
          minimumFractionDigits: 2
        }).format(amount);
      }
    }

    customElements.define('cart-discount-{{ ai_gen_id }}', CartDiscount{{ ai_gen_id }});
  })();
</script>

