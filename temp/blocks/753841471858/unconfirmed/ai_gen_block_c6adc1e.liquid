{% doc %}
  @prompt
    Create a standalone SECTION for the Shopify cart page template called "Cart Discount Code". Must appear as an addable section in the theme editor left panel on the cart page. All values must come from theme editor settings — absolutely no hardcoded discount values, codes, or text.
    
    Theme editor settings required:
    - discount_code: text field — the valid code to accept
    - discount_type: select — "percentage" or "fixed"
    - discount_value: number — the amount
    - input_placeholder: text
    - button_label: text
    - success_message: text
    - error_message: text
    
    Functional requirements (all via JavaScript, no page reload):
    1. Customer types a code and clicks Apply
    2. Code is compared (case-insensitive) against the discount_code setting
    3. If valid:
      a. Calculate discounted price for each line item and show strikethrough original + new price
      b. Read the current cart subtotal from the page — target ALL of these selectors: .cart-subtotal, .totals__subtotal, [data-cart-subtotal], .cart__subtotal, .order-summary__subtotal
      c. Calculate and update the subtotal DOM element with the discounted subtotal
      d. Also update the estimated total — target: .totals__total, .cart-total, [data-cart-total], .cart__total, .order-summary__total-price
      e. Show a "You save ₹X" line below the total
      f. Update ALL checkout button hrefs to append ?discount=CODE
      g. Use MutationObserver to re-apply all updates if cart re-renders
    4. If invalid: show error message
    
    Styling: minimal, luxury, editorial, clean sans-serif, no heavy borders, mobile responsive.
{% enddoc %}
{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-discount-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 24px 0;
    margin: 0;
  }

  .ai-cart-discount-container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-cart-discount-form-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-cart-discount-input-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid rgba(18, 18, 18, 0.55);
    border-radius: 0;
    font-family: {{ section.settings.type_body_font.family }}, sans-serif;
    font-size: 14px;
    background: #ffffff;
    color: #121212;
  }

  .ai-cart-discount-input-{{ ai_gen_id }}::placeholder {
    color: rgba(18, 18, 18, 0.5);
  }

  .ai-cart-discount-button-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: #121212;
    color: #ffffff;
    border: 4px solid #121212;
    border-radius: 0;
    font-family: {{ section.settings.type_body_font.family }}, sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .ai-cart-discount-button-{{ ai_gen_id }}:hover {
    background-color: #000000;
    border-color: #000000;
  }

  .ai-cart-discount-message-{{ ai_gen_id }} {
    font-family: {{ section.settings.type_body_font.family }}, sans-serif;
    font-size: 13px;
    padding: 8px 0;
    display: none;
  }

  .ai-cart-discount-message-{{ ai_gen_id }}.success {
    color: #008060;
    display: block;
  }

  .ai-cart-discount-message-{{ ai_gen_id }}.error {
    color: #D82C0D;
    display: block;
  }

  .ai-cart-discount-savings-{{ ai_gen_id }} {
    font-family: {{ section.settings.type_body_font.family }}, sans-serif;
    font-size: 14px;
    color: #008060;
    font-weight: 600;
    margin-top: 8px;
    display: none;
  }

  .ai-cart-discount-savings-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-cart-discount-line-price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-cart-discount-original-price-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    font-size: 14px;
  }

  .ai-cart-discount-new-price-{{ ai_gen_id }} {
    color: #008060;
    font-weight: 600;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-cart-discount-{{ ai_gen_id }} {
      padding: 16px 0;
    }

    .ai-cart-discount-form-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-discount-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<cart-discount-{{ ai_gen_id }}
  class="ai-cart-discount-{{ ai_gen_id }}"
  data-discount-code="{{ section.settings.discount_code }}"
  data-discount-type="{{ section.settings.discount_type }}"
  data-discount-value="{{ section.settings.discount_value }}"
  data-success-message="{{ section.settings.success_message }}"
  data-error-message="{{ section.settings.error_message }}"
  {{ section.shopify_attributes }}
>
  <div class="ai-cart-discount-container-{{ ai_gen_id }}">
    <div class="ai-cart-discount-form-{{ ai_gen_id }}">
      <input
        type="text"
        class="ai-cart-discount-input-{{ ai_gen_id }}"
        placeholder="{{ section.settings.input_placeholder }}"
        aria-label="Discount code"
      >
      <button
        type="button"
        class="ai-cart-discount-button-{{ ai_gen_id }}"
      >
        {{ section.settings.button_label }}
      </button>
    </div>
    <div class="ai-cart-discount-message-{{ ai_gen_id }}"></div>
    <div class="ai-cart-discount-savings-{{ ai_gen_id }}"></div>
  </div>
</cart-discount-{{ ai_gen_id }}>

<script>
  (function() {
    class CartDiscount{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.discountCode = this.dataset.discountCode.toLowerCase();
        this.discountType = this.dataset.discountType;
        this.discountValue = parseFloat(this.dataset.discountValue);
        this.successMessage = this.dataset.successMessage;
        this.errorMessage = this.dataset.errorMessage;
        this.isDiscountApplied = false;
        this.originalPrices = new Map();
      }

      connectedCallback() {
        this.input = this.querySelector('.ai-cart-discount-input-{{ ai_gen_id }}');
        this.button = this.querySelector('.ai-cart-discount-button-{{ ai_gen_id }}');
        this.message = this.querySelector('.ai-cart-discount-message-{{ ai_gen_id }}');
        this.savings = this.querySelector('.ai-cart-discount-savings-{{ ai_gen_id }}');

        this.button.addEventListener('click', () => this.applyDiscount());
        this.input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            this.applyDiscount();
          }
        });

        this.setupMutationObserver();
      }

      applyDiscount() {
        const enteredCode = this.input.value.trim().toLowerCase();

        if (enteredCode === this.discountCode) {
          this.isDiscountApplied = true;
          this.showMessage(this.successMessage, 'success');
          this.updateCartPrices();
          this.updateCheckoutButtons();
        } else {
          this.isDiscountApplied = false;
          this.showMessage(this.errorMessage, 'error');
          this.resetCartPrices();
        }
      }

      showMessage(text, type) {
        this.message.textContent = text;
        this.message.className = 'ai-cart-discount-message-{{ ai_gen_id }} ' + type;
      }

      updateCartPrices() {
        const lineItems = document.querySelectorAll('[data-cart-item], .cart-item, .cart__item, cart-item');
        let totalSavings = 0;

        lineItems.forEach((item) => {
          const priceElement = item.querySelector('[data-cart-item-price], .cart-item__price, .price, .cart__price');
          if (!priceElement) return;

          const priceText = priceElement.textContent.trim();
          const priceMatch = priceText.match(/[\d,]+\.?\d*/);
          if (!priceMatch) return;

          const originalPrice = parseFloat(priceMatch[0].replace(/,/g, ''));
          if (isNaN(originalPrice)) return;

          const itemKey = item.dataset.key || item.dataset.lineItem || Math.random().toString();
          if (!this.originalPrices.has(itemKey)) {
            this.originalPrices.set(itemKey, {
              element: priceElement,
              originalHTML: priceElement.innerHTML,
              price: originalPrice
            });
          }

          const discountedPrice = this.calculateDiscountedPrice(originalPrice);
          const savings = originalPrice - discountedPrice;
          totalSavings += savings;

          const currencySymbol = priceText.match(/[₹$€£¥]/)?.[0] || '₹';
          
          priceElement.innerHTML = `
            <div class="ai-cart-discount-line-price-{{ ai_gen_id }}">
              <span class="ai-cart-discount-original-price-{{ ai_gen_id }}">${currencySymbol}${originalPrice.toFixed(2)}</span>
              <span class="ai-cart-discount-new-price-{{ ai_gen_id }}">${currencySymbol}${discountedPrice.toFixed(2)}</span>
            </div>
          `;
        });

        this.updateSubtotal();
        this.updateTotal();
        this.showSavings(totalSavings);
      }

      calculateDiscountedPrice(price) {
        if (this.discountType === 'percentage') {
          return price * (1 - this.discountValue / 100);
        } else {
          return Math.max(0, price - this.discountValue);
        }
      }

      updateSubtotal() {
        const subtotalSelectors = [
          '.cart-subtotal',
          '.totals__subtotal',
          '[data-cart-subtotal]',
          '.cart__subtotal',
          '.order-summary__subtotal',
          '.totals__subtotal-value'
        ];

        subtotalSelectors.forEach((selector) => {
          const elements = document.querySelectorAll(selector);
          elements.forEach((element) => {
            const priceText = element.textContent.trim();
            const priceMatch = priceText.match(/[\d,]+\.?\d*/);
            if (!priceMatch) return;

            const originalSubtotal = parseFloat(priceMatch[0].replace(/,/g, ''));
            if (isNaN(originalSubtotal)) return;

            const discountedSubtotal = this.calculateDiscountedPrice(originalSubtotal);
            const currencySymbol = priceText.match(/[₹$€£¥]/)?.[0] || '₹';
            
            element.textContent = `${currencySymbol}${discountedSubtotal.toFixed(2)}`;
          });
        });
      }

      updateTotal() {
        const totalSelectors = [
          '.totals__total',
          '.cart-total',
          '[data-cart-total]',
          '.cart__total',
          '.order-summary__total-price',
          '.totals__total-value'
        ];

        totalSelectors.forEach((selector) => {
          const elements = document.querySelectorAll(selector);
          elements.forEach((element) => {
            const priceText = element.textContent.trim();
            const priceMatch = priceText.match(/[\d,]+\.?\d*/);
            if (!priceMatch) return;

            const originalTotal = parseFloat(priceMatch[0].replace(/,/g, ''));
            if (isNaN(originalTotal)) return;

            const discountedTotal = this.calculateDiscountedPrice(originalTotal);
            const currencySymbol = priceText.match(/[₹$€£¥]/)?.[0] || '₹';
            
            element.textContent = `${currencySymbol}${discountedTotal.toFixed(2)}`;
          });
        });
      }

      showSavings(amount) {
        if (amount > 0) {
          const currencySymbol = '₹';
          this.savings.textContent = `You save ${currencySymbol}${amount.toFixed(2)}`;
          this.savings.classList.add('active');
        } else {
          this.savings.classList.remove('active');
        }
      }

      updateCheckoutButtons() {
        const checkoutButtons = document.querySelectorAll(
          'a[href*="/checkout"], button[name="checkout"], .cart__checkout-button, [data-checkout-button]'
        );

        checkoutButtons.forEach((button) => {
          if (button.tagName === 'A') {
            const url = new URL(button.href);
            url.searchParams.set('discount', this.dataset.discountCode);
            button.href = url.toString();
          } else if (button.tagName === 'BUTTON') {
            const form = button.closest('form');
            if (form) {
              let discountInput = form.querySelector('input[name="discount"]');
              if (!discountInput) {
                discountInput = document.createElement('input');
                discountInput.type = 'hidden';
                discountInput.name = 'discount';
                form.appendChild(discountInput);
              }
              discountInput.value = this.dataset.discountCode;
            }
          }
        });
      }

      resetCartPrices() {
        this.originalPrices.forEach((data) => {
          data.element.innerHTML = data.originalHTML;
        });
        this.savings.classList.remove('active');
        
        const checkoutButtons = document.querySelectorAll('a[href*="/checkout"]');
        checkoutButtons.forEach((button) => {
          if (button.tagName === 'A') {
            const url = new URL(button.href);
            url.searchParams.delete('discount');
            button.href = url.toString();
          }
        });
      }

      setupMutationObserver() {
        const observer = new MutationObserver(() => {
          if (this.isDiscountApplied) {
            setTimeout(() => {
              this.updateCartPrices();
              this.updateCheckoutButtons();
            }, 100);
          }
        });

        const cartContainer = document.querySelector('cart-items, .cart, .cart-drawer, [data-cart]');
        if (cartContainer) {
          observer.observe(cartContainer, {
            childList: true,
            subtree: true
          });
        }
      }
    }

    customElements.define('cart-discount-{{ ai_gen_id }}', CartDiscount{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Cart discount code",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Discount settings"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code",
      "default": "SAVE10"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Discount type",
      "options": [
        {
          "value": "percentage",
          "label": "Percentage"
        },
        {
          "value": "fixed",
          "label": "Fixed amount"
        }
      ],
      "default": "percentage"
    },
    {
      "type": "range",
      "id": "discount_value",
      "label": "Discount value",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Form settings"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Enter discount code"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Apply"
    },
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Discount applied successfully!"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "Invalid discount code. Please try again."
    }
  ],
  "presets": [
    {
      "name": "Cart discount code"
    }
  ]
}
{% endschema %}
