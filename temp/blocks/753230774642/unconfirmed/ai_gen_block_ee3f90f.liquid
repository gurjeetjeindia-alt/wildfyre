{% endstyle %}

<dossier-reviews-{{ ai_gen_id }} class="ai-dossier-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dossier-reviews__container-{{ ai_gen_id }}">
    <div class="ai-dossier-reviews__header-{{ ai_gen_id }}">
      <h2 class="ai-dossier-reviews__title-{{ ai_gen_id }}">Customer Reviews</h2>
      
      <div class="ai-dossier-reviews__rating-summary-{{ ai_gen_id }}">
        <div class="ai-dossier-reviews__avg-rating-{{ ai_gen_id }}">{{ block.settings.average_rating }}</div>
        <div>
          <div class="ai-dossier-reviews__stars-{{ ai_gen_id }}">
            {% for i in (1..5) %}
              <svg class="ai-dossier-reviews__star-{{ ai_gen_id }}" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
            {% endfor %}
          </div>
          <div class="ai-dossier-reviews__count-{{ ai_gen_id }}">Based on {{ block.settings.review_count }} reviews</div>
        </div>
      </div>

      <div class="ai-dossier-reviews__rating-bars-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% assign star_num = 6 | minus: i %}
          {% assign percent_key = 'rating_' | append: star_num | append: '_percent' %}
          {% assign percent = block.settings[percent_key] %}
          <div class="ai-dossier-reviews__bar-row-{{ ai_gen_id }}">
            <div class="ai-dossier-reviews__bar-label-{{ ai_gen_id }}">{{ star_num }} stars</div>
            <div class="ai-dossier-reviews__bar-track-{{ ai_gen_id }}">
              <div class="ai-dossier-reviews__bar-fill-{{ ai_gen_id }}" style="width: {{ percent }}%;"></div>
            </div>
            <div class="ai-dossier-reviews__bar-percent-{{ ai_gen_id }}">{{ percent }}%</div>
          </div>
        {% endfor %}
      </div>

      <button class="ai-dossier-reviews__write-btn-{{ ai_gen_id }}" data-action="open-modal">
        Write a Review
      </button>
    </div>

    <div class="ai-dossier-reviews__tabs-{{ ai_gen_id }}">
      <button class="ai-dossier-reviews__tab-{{ ai_gen_id }} active" data-tab="reviews">
        Reviews
      </button>
      <button class="ai-dossier-reviews__tab-{{ ai_gen_id }}" data-tab="questions">
        Questions
      </button>
    </div>

    <div class="ai-dossier-reviews__panel-{{ ai_gen_id }} active" data-panel="reviews">
      <div class="ai-dossier-reviews__controls-{{ ai_gen_id }}">
        <label class="ai-dossier-reviews__sort-label-{{ ai_gen_id }}">Sort:</label>
        <select class="ai-dossier-reviews__sort-select-{{ ai_gen_id }}" data-sort-select>
          <option value="rating">Highest Rating</option>
          <option value="recent">Most Recent</option>
        </select>
      </div>

      <div class="ai-dossier-reviews__list-{{ ai_gen_id }}" data-reviews-list>
        {% for i in (1..3) %}
          {% liquid
            assign title_key = 'review_' | append: i | append: '_title'
            assign text_key = 'review_' | append: i | append: '_text'
            assign author_key = 'review_' | append: i | append: '_author'
            assign date_key = 'review_' | append: i | append: '_date'
            assign rating_key = 'review_' | append: i | append: '_rating'
            assign verified_key = 'review_' | append: i | append: '_verified'
            assign response_key = 'review_' | append: i | append: '_response'

            assign title = block.settings[title_key]
            assign text = block.settings[text_key]
            assign author = block.settings[author_key]
            assign date = block.settings[date_key]
            assign rating = block.settings[rating_key]
            assign verified = block.settings[verified_key]
            assign response = block.settings[response_key]
          %}

          <div class="ai-dossier-reviews__card-{{ ai_gen_id }}" data-rating="{{ rating }}" data-date="{{ date }}">
            <div class="ai-dossier-reviews__card-header-{{ ai_gen_id }}">
              <div class="ai-dossier-reviews__card-stars-{{ ai_gen_id }}">
                {% for j in (1..rating) %}
                  <svg class="ai-dossier-reviews__card-star-{{ ai_gen_id }}" viewBox="0 0 20 20">
                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                  </svg>
                {% endfor %}
              </div>
              {% if verified %}
                <div class="ai-dossier-reviews__card-verified-{{ ai_gen_id }}">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 0L10.472 5.528L16 8L10.472 10.472L8 16L5.528 10.472L0 8L5.528 5.528L8 0Z" fill="#008060"/>
                  </svg>
                  Verified Purchase
                </div>
              {% endif %}
            </div>
            <h3 class="ai-dossier-reviews__card-title-{{ ai_gen_id }}">{{ title }}</h3>
            <p class="ai-dossier-reviews__card-text-{{ ai_gen_id }}">{{ text }}</p>
            <div class="ai-dossier-reviews__card-meta-{{ ai_gen_id }}">
              {{ author }} • {{ date }}
            </div>
            {% if response != blank %}
              <div class="ai-dossier-reviews__card-response-{{ ai_gen_id }}">
                <div class="ai-dossier-reviews__response-label-{{ ai_gen_id }}">Response from {{ block.settings.brand_name }}:</div>
                <div class="ai-dossier-reviews__response-text-{{ ai_gen_id }}">{{ response }}</div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-dossier-reviews__panel-{{ ai_gen_id }}" data-panel="questions">
      <div class="ai-dossier-reviews__qa-list-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign question_key = 'question_' | append: i
            assign answer_key = 'answer_' | append: i
            assign question = block.settings[question_key]
            assign answer = block.settings[answer_key]
          %}
          {% if question != blank %}
            <div class="ai-dossier-reviews__qa-item-{{ ai_gen_id }}">
              <h3 class="ai-dossier-reviews__question-{{ ai_gen_id }}">Q: {{ question }}</h3>
              <p class="ai-dossier-reviews__answer-{{ ai_gen_id }}">A: {{ answer }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="ai-dossier-reviews__ask-form-{{ ai_gen_id }}">
        <h3 class="ai-dossier-reviews__ask-title-{{ ai_gen_id }}">Have a question?</h3>
        <input 
          type="text" 
          class="ai-dossier-reviews__ask-input-{{ ai_gen_id }}" 
          placeholder="Type your question here..."
          data-question-input
        >
        <button class="ai-dossier-reviews__ask-btn-{{ ai_gen_id }}" data-submit-question>
          Submit Question
        </button>
        <div class="ai-dossier-reviews__ask-success-{{ ai_gen_id }}" data-question-success>
          Thank you! Your question has been submitted.
        </div>
      </div>
    </div>

    {% if block.settings.cta_button_text != blank %}
      <div class="ai-dossier-reviews__cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_button_link }}" class="ai-dossier-reviews__cta-btn-{{ ai_gen_id }}">
          {{ block.settings.cta_button_text }}
        </a>
      </div>
    {% endif %}
  </div>

  <div class="ai-dossier-reviews__modal-{{ ai_gen_id }}" data-modal>
    <div class="ai-dossier-reviews__modal-content-{{ ai_gen_id }}">
      <button class="ai-dossier-reviews__modal-close-{{ ai_gen_id }}" data-close-modal>&times;</button>
      
      <div data-form-view>
        <h2 class="ai-dossier-reviews__modal-title-{{ ai_gen_id }}">Write a Review</h2>
        
        <div class="ai-dossier-reviews__form-group-{{ ai_gen_id }}">
          <label class="ai-dossier-reviews__form-label-{{ ai_gen_id }}">Rating</label>
          <div class="ai-dossier-reviews__star-rating-{{ ai_gen_id }}" data-star-rating>
            {% for i in (1..5) %}
              <button class="ai-dossier-reviews__star-btn-{{ ai_gen_id }}" data-star="{{ i }}" type="button">
                <svg class="ai-dossier-reviews__star-btn-icon-{{ ai_gen_id }}" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              </button>
            {% endfor %}
          </div>
        </div>

        <div class="ai-dossier-reviews__form-group-{{ ai_gen_id }}">
          <label class="ai-dossier-reviews__form-label-{{ ai_gen_id }}">Review Title</label>
          <input type="text" class="ai-dossier-reviews__form-input-{{ ai_gen_id }}" data-review-title>
        </div>

        <div class="ai-dossier-reviews__form-group-{{ ai_gen_id }}">
          <label class="ai-dossier-reviews__form-label-{{ ai_gen_id }}">Review</label>
          <textarea class="ai-dossier-reviews__form-textarea-{{ ai_gen_id }}" data-review-body></textarea>
        </div>

        <div class="ai-dossier-reviews__form-group-{{ ai_gen_id }}">
          <label class="ai-dossier-reviews__form-label-{{ ai_gen_id }}">Your Name</label>
          <input type="text" class="ai-dossier-reviews__form-input-{{ ai_gen_id }}" data-review-author>
        </div>

        <button class="ai-dossier-reviews__form-submit-{{ ai_gen_id }}" data-submit-review>
          Submit Review
        </button>
      </div>

      <div class="ai-dossier-reviews__thank-you-{{ ai_gen_id }}" data-thank-you-view>
        <h2 class="ai-dossier-reviews__thank-you-title-{{ ai_gen_id }}">Thank You!</h2>
        <p class="ai-dossier-reviews__thank-you-text-{{ ai_gen_id }}">Your review has been submitted successfully.</p>
      </div>
    </div>
  </div>
</dossier-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class DossierReviews{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.modal = this.querySelector('[data-modal]');
        this.formView = this.querySelector('[data-form-view]');
        this.thankYouView = this.querySelector('[data-thank-you-view]');
        this.selectedRating = 0;
        this.reviewsList = this.querySelector('[data-reviews-list]');
        this.reviews = Array.from(this.reviewsList.querySelectorAll('.ai-dossier-reviews__card-{{ ai_gen_id }}'));
      }

      connectedCallback() {
        this.setupModalListeners();
        this.setupTabListeners();
        this.setupStarRating();
        this.setupReviewSubmit();
        this.setupSortListener();
        this.setupQuestionSubmit();
      }

      setupModalListeners() {
        const openBtn = this.querySelector('[data-action="open-modal"]');
        const closeBtn = this.querySelector('[data-close-modal]');
        const modalOverlay = this.modal;

        openBtn.addEventListener('click', () => {
          this.modal.classList.add('active');
          this.formView.style.display = 'block';
          this.thankYouView.style.display = 'none';
          this.resetForm();
        });

        closeBtn.addEventListener('click', () => {
          this.modal.classList.remove('active');
        });

        modalOverlay.addEventListener('click', (e) => {
          if (e.target === modalOverlay) {
            this.modal.classList.remove('active');
          }
        });
      }

      setupTabListeners() {
        const tabs = this.querySelectorAll('.ai-dossier-reviews__tab-{{ ai_gen_id }}');
        const panels = this.querySelectorAll('.ai-dossier-reviews__panel-{{ ai_gen_id }}');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const targetPanel = tab.dataset.tab;

            tabs.forEach(t => t.classList.remove('active'));
            panels.forEach(p => p.classList.remove('active'));

            tab.classList.add('active');
            this.querySelector(`[data-panel="${targetPanel}"]`).classList.add('active');
          });
        });
      }

      setupStarRating() {
        const starBtns = this.querySelectorAll('[data-star]');

        starBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const rating = parseInt(btn.dataset.star);
            this.selectedRating = rating;

            starBtns.forEach((b, index) => {
              if (index < rating) {
                b.classList.add('active');
              } else {
                b.classList.remove('active');
              }
            });
          });
        });
      }

      setupReviewSubmit() {
        const submitBtn = this.querySelector('[data-submit-review]');

        submitBtn.addEventListener('click', () => {
          this.formView.style.display = 'none';
          this.thankYouView.style.display = 'block';

          setTimeout(() => {
            this.modal.classList.remove('active');
          }, 2000);
        });
      }

      setupSortListener() {
        const sortSelect = this.querySelector('[data-sort-select]');

        sortSelect.addEventListener('change', (e) => {
          const sortType = e.target.value;
          this.sortReviews(sortType);
        });
      }

      sortReviews(sortType) {
        const sortedReviews = [...this.reviews].sort((a, b) => {
          if (sortType === 'rating') {
            return parseInt(b.dataset.rating) - parseInt(a.dataset.rating);
          } else if (sortType === 'recent') {
            const dateA = new Date(a.dataset.date);
            const dateB = new Date(b.dataset.date);
            return dateB - dateA;
          }
          return 0;
        });

        this.reviewsList.innerHTML = '';
        sortedReviews.forEach(review => {
          this.reviewsList.appendChild(review);
        });
      }

      setupQuestionSubmit() {
        const submitBtn = this.querySelector('[data-submit-question]');
        const input = this.querySelector('[data-question-input]');
        const success = this.querySelector('[data-question-success]');

        submitBtn.addEventListener('click', () => {
          if (input.value.trim()) {
            success.style.display = 'block';
            input.value = '';

            setTimeout(() => {
              success.style.display = 'none';
            }, 3000);
          }
        });
      }

      resetForm() {
        this.selectedRating = 0;
        this.querySelectorAll('[data-star]').forEach(btn => btn.classList.remove('active'));
        this.querySelector('[data-review-title]').value = '';
        this.querySelector('[data-review-body]').value = '';
        this.querySelector('[data-review-author]').value = '';
      }
    }

    customElements.define('dossier-reviews-{{ ai_gen_id }}', DossierReviews{{ ai_gen_id }});
  })();
</script>

