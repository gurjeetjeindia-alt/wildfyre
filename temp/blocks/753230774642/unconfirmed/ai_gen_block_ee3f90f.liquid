  @media screen and (max-width: 749px) {
    .ai-dossier-reviews__modal-content-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-dossier-reviews__tabs-{{ ai_gen_id }} {
      gap: 24px;
    }

    .ai-dossier-reviews__controls-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
