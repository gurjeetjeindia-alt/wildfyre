  .ai-dossier-reviews__modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .ai-dossier-reviews__modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-dossier-reviews__modal-content-{{ ai_gen_id }} {
    background-color: #ffffff;
    width: 90%;
    max-width: 600px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 48px;
    position: relative;
