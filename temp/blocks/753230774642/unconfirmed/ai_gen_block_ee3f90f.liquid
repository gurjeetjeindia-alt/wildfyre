  }

  .ai-dossier-reviews__thank-you-{{ ai_gen_id }} {
    display: none;
    text-align: center;
  }

  .ai-dossier-reviews__thank-you-title-{{ ai_gen_id }} {
    font-family: 'EB Garamond', serif;
    font-size: 32px;
    font-weight: 400;
    color: #000000;
    margin: 0 0 16px;
  }

  .ai-dossier-reviews__thank-you-text-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
