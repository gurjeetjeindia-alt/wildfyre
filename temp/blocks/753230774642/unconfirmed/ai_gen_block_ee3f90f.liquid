  .ai-dossier-reviews__form-input-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    width: 100%;
    padding: 12px;
    border: 1px solid #e0e0e0;
  }

  .ai-dossier-reviews__form-textarea-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    width: 100%;
    padding: 12px;
    border: 1px solid #e0e0e0;
    min-height: 120px;
    resize: vertical;
  }

  .ai-dossier-reviews__form-submit-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 12px 32px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    cursor: pointer;
    width: 100%;
    transition: background-color 0.2s ease;
  }

  .ai-dossier-reviews__form-submit-{{ ai_gen_id }}:hover {
