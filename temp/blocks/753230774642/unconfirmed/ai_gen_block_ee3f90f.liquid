  }

  .ai-dossier-reviews__ask-title-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #000000;
    margin: 0 0 16px;
  }

  .ai-dossier-reviews__ask-input-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    width: 100%;
    padding: 12px;
    border: 1px solid #e0e0e0;
