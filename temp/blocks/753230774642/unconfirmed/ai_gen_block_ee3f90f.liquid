  .ai-dossier-reviews__cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 48px;
  }

  .ai-dossier-reviews__cta-btn-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 12px 32px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .ai-dossier-reviews__cta-btn-{{ ai_gen_id }}:hover {
