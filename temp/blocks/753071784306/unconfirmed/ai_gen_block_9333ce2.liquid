{% doc %}
  @prompt
    create a review section just like the dossier website we want same ui like that website https://dossier.co/products/ambery-saffron?Size=100ml this is the link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-reviews-rating-summary-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ai-reviews-average-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1;
  }

  .ai-reviews-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-reviews-star-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-star-{{ ai_gen_id }}.empty {
    fill: {{ block.settings.empty_star_color }};
  }

  .ai-reviews-count-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.secondary_text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.secondary_text_color }};
    margin: 0;
  }

  .ai-reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  .ai-review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-review-card-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .ai-review-card-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 3px;
  }

  .ai-review-card-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-card-star-{{ ai_gen_id }}.empty {
    fill: {{ block.settings.empty_star_color }};
  }

  .ai-review-verified-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.verified_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .ai-review-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-review-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-review-author-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-review-author-name-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-review-author-date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.secondary_text_color }};
  }

  .ai-reviews-cta-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-reviews-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-reviews-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-reviews-average-{{ ai_gen_id }} {
      font-size: 36px;
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-review-card-{{ ai_gen_id }} {
      padding: 24px 20px;
    }
  }
{% endstyle %}

<reviews-section-{{ ai_gen_id }} class="ai-reviews-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-header-{{ ai_gen_id }}">
    <div class="ai-reviews-rating-summary-{{ ai_gen_id }}">
      <div class="ai-reviews-average-{{ ai_gen_id }}">{{ block.settings.average_rating }}</div>
      <div class="ai-reviews-stars-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% if i <= block.settings.average_rating %}
            <svg class="ai-reviews-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
            </svg>
          {% else %}
            <svg class="ai-reviews-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
            </svg>
          {% endif %}
        {% endfor %}
      </div>
      <div class="ai-reviews-count-{{ ai_gen_id }}">Based on {{ block.settings.review_count }} reviews</div>
    </div>
    
    {% if block.settings.section_title != blank %}
      <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}
    
    {% if block.settings.section_subtitle != blank %}
      <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
    {% endif %}
  </div>

  <div class="ai-reviews-grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign review_rating_key = 'review_' | append: i | append: '_rating'
        assign review_title_key = 'review_' | append: i | append: '_title'
        assign review_text_key = 'review_' | append: i | append: '_text'
        assign review_author_key = 'review_' | append: i | append: '_author'
        assign review_date_key = 'review_' | append: i | append: '_date'
        assign review_verified_key = 'review_' | append: i | append: '_verified'

        assign review_rating = block.settings[review_rating_key]
        assign review_title = block.settings[review_title_key]
        assign review_text = block.settings[review_text_key]
        assign review_author = block.settings[review_author_key]
        assign review_date = block.settings[review_date_key]
        assign review_verified = block.settings[review_verified_key]
      %}

      <div class="ai-review-card-{{ ai_gen_id }}">
        <div class="ai-review-card-header-{{ ai_gen_id }}">
          <div class="ai-review-card-stars-{{ ai_gen_id }}">
            {% for star in (1..5) %}
              {% if star <= review_rating %}
                <svg class="ai-review-card-star-{{ ai_gen_id }}" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {% else %}
                <svg class="ai-review-card-star-{{ ai_gen_id }} empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>
          {% if review_verified %}
            <span class="ai-review-verified-{{ ai_gen_id }}">Verified</span>
          {% endif %}
        </div>

        {% if review_title != blank %}
          <h3 class="ai-review-title-{{ ai_gen_id }}">{{ review_title }}</h3>
        {% endif %}

        {% if review_text != blank %}
          <p class="ai-review-text-{{ ai_gen_id }}">{{ review_text }}</p>
        {% endif %}

        <div class="ai-review-author-{{ ai_gen_id }}">
          {% if review_author != blank %}
            <div class="ai-review-author-name-{{ ai_gen_id }}">{{ review_author }}</div>
          {% endif %}
          {% if review_date != blank %}
            <div class="ai-review-author-date-{{ ai_gen_id }}">{{ review_date }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% if block.settings.show_cta_button %}
    <div class="ai-reviews-cta-{{ ai_gen_id }}">
      <a href="{{ block.settings.button_link }}" class="ai-reviews-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    </div>
  {% endif %}
</reviews-section-{{ ai_gen_id }}>

