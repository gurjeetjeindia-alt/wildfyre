{% comment %}
  Video Banner Section
{% endcomment %}

<section
  class="video-banner"
  style="
    --banner-height-desktop: {{ section.settings.height_desktop }}vh;
    --banner-height-mobile: {{ section.settings.height_mobile }}vh;
  "
>
  <div class="video-banner__media">

    {% assign has_mobile_video = false %}
    {% if section.settings.mobile_video != blank or section.settings.mobile_video_url != blank %}
      {% assign has_mobile_video = true %}
    {% endif %}

    <!-- Desktop Video -->
    <video
      class="video-banner__video {% if has_mobile_video %}video--desktop{% endif %}"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      {% if section.settings.cover_image != blank %}
        poster="{{ section.settings.cover_image | image_url }}"
      {% endif %}
    >
      {% if section.settings.video != blank %}
        <source src="{{ section.settings.video.sources[0].url }}" type="video/mp4">
      {% elsif section.settings.video_url != blank %}
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      {% endif %}
    </video>

    {% if has_mobile_video %}
      <!-- Mobile Video -->
      <video
        class="video-banner__video video--mobile"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        {% if section.settings.cover_image != blank %}
          poster="{{ section.settings.cover_image | image_url }}"
        {% endif %}
      >
        {% if section.settings.mobile_video != blank %}
          <source src="{{ section.settings.mobile_video.sources[0].url }}" type="video/mp4">
        {% elsif section.settings.mobile_video_url != blank %}
          <source src="{{ section.settings.mobile_video_url }}" type="video/mp4">
        {% endif %}
      </video>
    {% endif %}

  </div>

  <div class="video-banner__overlay">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="video-banner__text">
        {{ section.settings.text }}
      </div>
    {% endif %}
  </div>
</section>

<style>
.video-banner {
  position: relative;
  width: 100%;
  height: var(--banner-height-desktop);
  overflow: hidden;
}

.video-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 1;
}

@media (max-width: 749px) {
  .video-banner {
    height: var(--banner-height-mobile);
  }
}

.video-banner__media,
.video-banner__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.video-banner__video {
  object-fit: cover;
}

.video--mobile {
  display: none;
}

@media (max-width: 749px) {
  .video--desktop {
    display: none;
  }

  .video--mobile {
    display: block;
  }
}

.video-banner__overlay {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: {{ section.settings.text_color }};
  text-align: center;
  padding: 2rem;
}

.video-banner__overlay h2 {
  font-size: clamp(2rem, 5vw, 5rem);
  font-family: 'Derma', sans-serif;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.video-banner__text {
  max-width: 90%;
  font-size: 1rem;
  line-height: 1.5;
}

@media(min-width:750px){
  .video-banner__overlay h2 {
    font-size: clamp(3rem, 6vw, 6rem);
    margin-bottom: 20px;
  }

  .video-banner__text {
    font-size: 1.1rem;
  }
}
</style>

{% schema %}
{
  "name": "Video Banner",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Desktop Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Desktop Video URL"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile Video"
    },
    {
      "type": "url",
      "id": "mobile_video_url",
      "label": "Mobile Video URL"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Poster Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WILDFYRE"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Desktop Height",
      "default": 100
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Mobile Height",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Video Banner"
    }
  ]
}
{% endschema %}



