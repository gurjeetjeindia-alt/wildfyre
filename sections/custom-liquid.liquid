{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.75);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    [data-custom-liquid-section="{{ section.id }}"] .wf-luxury {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-split {
      display: flex !important;
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      width: 100%;
      scroll-snap-type: none;
      scroll-behavior: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      overscroll-behavior-x: contain;
      touch-action: pan-y pinch-zoom;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-split::-webkit-scrollbar {
      display: none;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-split > * {
      flex: 0 0 100vw;
      min-width: 100vw;
      scroll-snap-align: start;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-panel {
      height: 72vh;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-content {
      left: 18px;
      right: 18px;
      bottom: 18px;
    }
  }
{%- endstyle -%}
<div class="color-{{ section.settings.color_scheme }} gradient" data-custom-liquid-section="{{ section.id }}">
  <div class="section-{{ section.id }}-padding">
    {{ section.settings.custom_liquid }}
  </div>
</div>

<script>
  (function () {
    const section = document.querySelector('[data-custom-liquid-section="{{ section.id }}"]');
    if (!section) return;

    const rail = section.querySelector('.wf-split');
    if (!rail) return;

    const mobileQuery = window.matchMedia('(max-width: 749px)');
    let stepTimer = 0;
    let pauseTimer = 0;
    let syncTimer = 0;
    let currentIndex = 0;
    let userInteracting = false;
    let initialized = false;
    let baseCount = 0;
    let trackStart = 0;
    let trackEnd = 0;
    let loopWidth = 0;
    let slideStep = 0;
    let wrapLock = false;
    let slides = [];

    function isMobile() {
      return mobileQuery.matches;
    }

    function clearTimers() {
      if (stepTimer) {
        clearInterval(stepTimer);
        stepTimer = 0;
      }
      if (pauseTimer) {
        clearTimeout(pauseTimer);
        pauseTimer = 0;
      }
      if (syncTimer) {
        clearTimeout(syncTimer);
        syncTimer = 0;
      }
    }

    function getSlides() {
      return Array.from(rail.children).filter((node) => node.classList && node.classList.contains('wf-panel'));
    }

    function ensureInfiniteTrack() {
      if (!isMobile() || initialized) return false;

      const originalSlides = getSlides();
      if (!originalSlides.length) return false;
      baseCount = originalSlides.length;

      const before = document.createDocumentFragment();
      const after = document.createDocumentFragment();

      originalSlides.forEach((node) => {
        before.appendChild(node.cloneNode(true));
        after.appendChild(node.cloneNode(true));
      });

      rail.insertBefore(before, rail.firstChild);
      rail.appendChild(after);

      initialized = true;
      return true;
    }

    function syncIndexFromScroll() {
      if (!slides.length) return;

      const scrollLeft = rail.scrollLeft;
      let closestIndex = 0;
      let closestDistance = Infinity;

      slides.forEach((slide, index) => {
        const distance = Math.abs(slide.offsetLeft - scrollLeft);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      currentIndex = closestIndex;
    }

    function measureLoop() {
      if (!slides.length) return;

      const middleStart = baseCount;
      const middleEnd = baseCount * 2;
      const startSlide = slides[middleStart];
      const endSlide = slides[middleEnd - 1];

      trackStart = startSlide ? startSlide.offsetLeft : 0;
      trackEnd = endSlide ? endSlide.offsetLeft + endSlide.offsetWidth : 0;
      loopWidth = Math.max(0, trackEnd - trackStart);

      if (baseCount > 1) {
        const nextSlide = slides[middleStart + 1];
        slideStep = nextSlide ? Math.max(1, nextSlide.offsetLeft - startSlide.offsetLeft) : startSlide.offsetWidth || 0;
      } else {
        slideStep = startSlide ? startSlide.offsetWidth : 0;
      }
    }

    function startAutoScroll() {
      if (!isMobile() || slides.length === 0 || !slideStep) return;

      if (stepTimer) return;

      stepTimer = window.setInterval(() => {
        if (!isMobile() || !slides.length) return;
        if (!userInteracting && !wrapLock) {
          rail.scrollBy({
            left: slideStep,
            behavior: 'smooth',
          });
          wrapScrollPosition();
        }
      }, 2000);
    }

    function wrapScrollPosition() {
      if (!isMobile() || !slides.length || !loopWidth) return;
      if (wrapLock) return;

      const scrollLeft = rail.scrollLeft;
      if (scrollLeft >= trackEnd) {
        wrapLock = true;
        const previousSnap = rail.style.scrollSnapType;
        rail.style.scrollSnapType = 'none';
        rail.scrollLeft = scrollLeft - loopWidth;
        window.requestAnimationFrame(() => {
          rail.style.scrollSnapType = previousSnap || '';
          wrapLock = false;
        });
      } else if (scrollLeft < trackStart) {
        wrapLock = true;
        const previousSnap = rail.style.scrollSnapType;
        rail.style.scrollSnapType = 'none';
        rail.scrollLeft = scrollLeft + loopWidth;
        window.requestAnimationFrame(() => {
          rail.style.scrollSnapType = previousSnap || '';
          wrapLock = false;
        });
        return;
      }
    }

    function resumeSoon() {
      if (!isMobile()) return;
      if (pauseTimer) clearTimeout(pauseTimer);
      pauseTimer = window.setTimeout(() => {
        userInteracting = false;
        syncIndexFromScroll();
        wrapScrollPosition();
      }, 700);
    }

    function bindInteractionPause() {
      rail.addEventListener('pointerdown', () => {
        if (!isMobile()) return;
        userInteracting = true;
        if (pauseTimer) clearTimeout(pauseTimer);
      });

      rail.addEventListener('pointerup', resumeSoon);
      rail.addEventListener('pointercancel', resumeSoon);
      rail.addEventListener('touchstart', () => {
        if (!isMobile()) return;
        userInteracting = true;
        if (pauseTimer) clearTimeout(pauseTimer);
      }, { passive: true });
      rail.addEventListener('touchend', resumeSoon);

      rail.addEventListener('scroll', () => {
        if (!isMobile()) return;
        wrapScrollPosition();
        if (syncTimer) clearTimeout(syncTimer);
        syncTimer = window.setTimeout(() => {
          if (!userInteracting) {
            syncIndexFromScroll();
          }
        }, 80);
      });
    }

    function refresh() {
      clearTimers();
      if (!isMobile()) {
        rail.style.scrollSnapType = '';
        rail.scrollLeft = 0;
        return;
      }

      if (!initialized) {
        ensureInfiniteTrack();
        bindInteractionPause();
      }

      slides = getSlides();
      if (!slides.length) return;

      measureLoop();
      userInteracting = false;
      if (!initialized || rail.scrollLeft < trackStart || rail.scrollLeft >= trackEnd) {
        rail.scrollLeft = trackStart || 0;
      }

      syncIndexFromScroll();
      wrapScrollPosition();
      startAutoScroll();
    }

    mobileQuery.addEventListener?.('change', refresh);
    window.addEventListener('resize', refresh);
    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        refresh();
      }
    });

    refresh();
  })();
</script>

{% schema %}
{
  "name": "t:sections.custom-liquid.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:sections.custom-liquid.settings.custom_liquid.label",
      "info": "t:sections.custom-liquid.settings.custom_liquid.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-liquid.presets.name"
    }
  ]
}
{% endschema %}
