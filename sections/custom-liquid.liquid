{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.75);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    [data-custom-liquid-section="{{ section.id }}"] .wf-luxury {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-split {
      display: flex !important;
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      width: 100%;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      overscroll-behavior-x: contain;
      touch-action: pan-x pinch-zoom;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-split::-webkit-scrollbar {
      display: none;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-split > * {
      flex: 0 0 100vw;
      min-width: 100vw;
      scroll-snap-align: start;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-panel {
      height: 72vh;
    }

    [data-custom-liquid-section="{{ section.id }}"] .wf-content {
      left: 18px;
      right: 18px;
      bottom: 18px;
    }
  }
{%- endstyle -%}
<div class="color-{{ section.settings.color_scheme }} gradient" data-custom-liquid-section="{{ section.id }}">
  <div class="section-{{ section.id }}-padding">
    {{ section.settings.custom_liquid }}
  </div>
</div>

<script>
  (function () {
    const section = document.querySelector('[data-custom-liquid-section="{{ section.id }}"]');
    if (!section) return;

    const rail = section.querySelector('.wf-split');
    if (!rail) return;

    const mobileQuery = window.matchMedia('(max-width: 749px)');
    let stepTimer = 0;
    let pauseTimer = 0;
    let syncTimer = 0;
    let currentIndex = 0;
    let userInteracting = false;
    let initialized = false;
    let baseCount = 0;
    let slides = [];

    function isMobile() {
      return mobileQuery.matches;
    }

    function clearTimers() {
      if (stepTimer) {
        clearTimeout(stepTimer);
        stepTimer = 0;
      }
      if (pauseTimer) {
        clearTimeout(pauseTimer);
        pauseTimer = 0;
      }
      if (syncTimer) {
        clearTimeout(syncTimer);
        syncTimer = 0;
      }
    }

    function getSlides() {
      return Array.from(rail.children).filter((node) => node.classList && node.classList.contains('wf-panel'));
    }

    function ensureInfiniteTrack() {
      if (!isMobile() || initialized) return false;

      const originalSlides = getSlides();
      if (!originalSlides.length) return false;
      baseCount = originalSlides.length;

      const before = document.createDocumentFragment();
      const after = document.createDocumentFragment();

      originalSlides.forEach((node) => {
        before.appendChild(node.cloneNode(true));
        after.appendChild(node.cloneNode(true));
      });

      rail.insertBefore(before, rail.firstChild);
      rail.appendChild(after);

      initialized = true;
      return true;
    }

    function normalizeIndex(index) {
      if (!baseCount) return Math.max(0, index);

      const loopStart = baseCount;
      const loopEnd = baseCount * 2;
      if (index < loopStart) return index + baseCount;
      if (index >= loopEnd) return index - baseCount;
      return index;
    }

    function jumpToIndex(index) {
      if (!slides.length) return;

      const targetIndex = Math.max(0, Math.min(slides.length - 1, index));
      currentIndex = targetIndex;

      const slide = slides[targetIndex];
      if (!slide) return;

      const previousSnap = rail.style.scrollSnapType;
      rail.style.scrollSnapType = 'none';
      rail.scrollLeft = slide.offsetLeft;
      window.requestAnimationFrame(() => {
        rail.style.scrollSnapType = previousSnap || '';
      });
    }

    function syncIndexFromScroll() {
      if (!slides.length) return;

      const scrollLeft = rail.scrollLeft;
      let closestIndex = 0;
      let closestDistance = Infinity;

      slides.forEach((slide, index) => {
        const distance = Math.abs(slide.offsetLeft - scrollLeft);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      currentIndex = closestIndex;
    }

    function scrollToIndex(index, behavior) {
      if (!slides.length) return;

      const clampedIndex = Math.max(0, Math.min(slides.length - 1, index));
      currentIndex = clampedIndex;

      const slide = slides[clampedIndex];
      if (!slide) return;

      rail.scrollTo({
        left: slide.offsetLeft,
        behavior,
      });
    }

    function startAutoScroll() {
      clearTimers();
      if (!isMobile() || slides.length === 0) return;

      stepTimer = window.setTimeout(function tick() {
        if (!isMobile() || userInteracting || slides.length === 0) return;
        const nextIndex = currentIndex + 1;
        if (nextIndex >= baseCount * 2) {
          scrollToIndex(nextIndex, 'smooth');
          window.setTimeout(() => {
            if (!isMobile() || userInteracting) return;
            if (currentIndex === nextIndex) {
              jumpToIndex(nextIndex - baseCount);
            }
          }, 350);
        } else if (nextIndex >= slides.length) {
          jumpToIndex(baseCount || 0);
        } else {
          scrollToIndex(nextIndex, 'smooth');
        }

        if (!isMobile() || userInteracting) return;
        stepTimer = window.setTimeout(tick, 1500);
      }, 1500);
    }

    function snapToLoopAnchor() {
      if (!isMobile() || !slides.length || !baseCount) return;

      const normalizedIndex = normalizeIndex(currentIndex);
      if (normalizedIndex !== currentIndex) {
        jumpToIndex(normalizedIndex);
        return;
      }
    }

    function resumeSoon() {
      if (!isMobile()) return;
      if (pauseTimer) clearTimeout(pauseTimer);
      pauseTimer = window.setTimeout(() => {
        userInteracting = false;
        syncIndexFromScroll();
        snapToLoopAnchor();
        startAutoScroll();
      }, 700);
    }

    function bindInteractionPause() {
      rail.addEventListener('pointerdown', () => {
        if (!isMobile()) return;
        userInteracting = true;
        if (pauseTimer) clearTimeout(pauseTimer);
      });

      rail.addEventListener('pointerup', resumeSoon);
      rail.addEventListener('pointercancel', resumeSoon);
      rail.addEventListener('touchstart', () => {
        if (!isMobile()) return;
        userInteracting = true;
        if (pauseTimer) clearTimeout(pauseTimer);
      }, { passive: true });
      rail.addEventListener('touchend', resumeSoon);

      rail.addEventListener('scroll', () => {
        if (!isMobile()) return;
        if (syncTimer) clearTimeout(syncTimer);
        syncTimer = window.setTimeout(() => {
          if (!userInteracting) {
            syncIndexFromScroll();
          }
        }, 80);
      });
    }

    function refresh() {
      clearTimers();
      if (!isMobile()) {
        rail.style.scrollSnapType = '';
        rail.scrollLeft = 0;
        return;
      }

      if (!initialized) {
        ensureInfiniteTrack();
        bindInteractionPause();
      }

      slides = getSlides();
      if (!slides.length) return;

      userInteracting = false;
      if (!currentIndex || currentIndex < baseCount || currentIndex >= baseCount * 2) {
        currentIndex = baseCount || 0;
      }
      syncIndexFromScroll();
      currentIndex = normalizeIndex(currentIndex);
      jumpToIndex(currentIndex);
      startAutoScroll();
    }

    mobileQuery.addEventListener?.('change', refresh);
    window.addEventListener('resize', refresh);
    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        refresh();
      }
    });

    refresh();
  })();
</script>

{% schema %}
{
  "name": "t:sections.custom-liquid.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:sections.custom-liquid.settings.custom_liquid.label",
      "info": "t:sections.custom-liquid.settings.custom_liquid.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-liquid.presets.name"
    }
  ]
}
{% endschema %}
