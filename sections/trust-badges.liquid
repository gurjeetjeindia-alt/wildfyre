<style>
.trust-badges-section {
  padding: 60px 40px;
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.trust-badges-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  text-align: center;
}

.trust-badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.trust-badge-icon {
  width: 40px;
  height: 40px;
  color: #111;
}

.trust-badge-title {
  font-size: 14px;
  font-weight: 600;
  color: #111;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin: 0;
}

.trust-badge-description {
  font-size: 13px;
  color: #666;
  line-height: 1.5;
  margin: 0;
  max-width: 200px;
}

@media(max-width: 749px) {
  .trust-badges-section {
    padding: 40px 20px;
  }
  
  .trust-badges-container {
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }
  
  .trust-badge-description {
    font-size: 12px;
  }
}
</style>

<div class="trust-badges-section">
  <div class="trust-badges-container">
    <div class="trust-badge-item">
      <svg class="trust-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"></path>
      </svg>
      <h3 class="trust-badge-title">Crafted in France</h3>
      <p class="trust-badge-description">Premium-quality fragrances made with passion</p>
    </div>
    
    <div class="trust-badge-item">
      <svg class="trust-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 4h16c1.1 0 2 0.9 2 2v12c0 1.1-0.9 2-2 2H4c-1.1 0-2-0.9-2-2V6c0-1.1 0.9-2 2-2Z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <h3 class="trust-badge-title">Free Returns</h3>
      <p class="trust-badge-description">No questions asked, 30-day returns</p>
    </div>
    
    <div class="trust-badge-item">
      <svg class="trust-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      <h3 class="trust-badge-title">Premium Quality</h3>
      <p class="trust-badge-description">Luxury fragrances without the markup</p>
    </div>
    
    <div class="trust-badge-item">
      <svg class="trust-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <h3 class="trust-badge-title">Cruelty-Free</h3>
      <p class="trust-badge-description">Ethical sourcing, never tested on animals</p>
    </div>
  </div>
</div>

