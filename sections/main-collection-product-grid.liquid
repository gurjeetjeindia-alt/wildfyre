{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    background:
      radial-gradient(circle at top right, rgba(176, 161, 141, 0.08), transparent 24%),
      linear-gradient(180deg, #faf6f2 0%, #fdf8f8 100%);
  }

  .section-{{ section.id }}-padding .collection {
    max-width: 1440px;
    margin: 0 auto;
    padding-inline: 5vw;
  }

  .section-{{ section.id }}-padding .facets-wrapper {
    padding-top: 0;
    margin-bottom: 2.2rem;
    border-bottom: 1px solid rgba(28, 27, 27, 0.08);
    padding-bottom: 1.8rem;
  }

  .section-{{ section.id }}-padding .facets__form,
  .section-{{ section.id }}-padding .facets-container,
  .section-{{ section.id }}-padding .product-count {
    align-items: center;
  }

  .section-{{ section.id }}-padding .facet-filters__label,
  .section-{{ section.id }}-padding .facets__heading,
  .section-{{ section.id }}-padding .facet-filters__sort,
  .section-{{ section.id }}-padding .product-count__text,
  .section-{{ section.id }}-padding .facets__summary,
  .section-{{ section.id }}-padding .active-facets__button-inner,
  .section-{{ section.id }}-padding .mobile-facets__summary,
  .section-{{ section.id }}-padding .mobile-facets__heading {
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }}-padding .facet-filters__label,
  .section-{{ section.id }}-padding .facets__heading,
  .section-{{ section.id }}-padding .facet-filters__sort,
  .section-{{ section.id }}-padding .product-count__text,
  .section-{{ section.id }}-padding .facets__summary,
  .section-{{ section.id }}-padding .mobile-facets__summary {
    color: rgba(28, 27, 27, 0.62);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .section-{{ section.id }}-padding .facet-filters__sort {
    padding-right: 2.2rem;
  }

  .section-{{ section.id }}-padding .active-facets {
    gap: 0.8rem;
    margin-top: 1.2rem;
  }

  .section-{{ section.id }}-padding .active-facets__button-inner {
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(28, 27, 27, 0.12);
    box-shadow: none;
    border-radius: 999px;
    color: #121212;
    padding: 0.8rem 1.2rem;
    transition: transform 220ms ease, border-color 220ms ease, background-color 220ms ease;
  }

  .section-{{ section.id }}-padding .active-facets__button:hover .active-facets__button-inner {
    transform: translateY(-1px);
    border-color: rgba(28, 27, 27, 0.28);
  }

  .section-{{ section.id }}-padding .product-grid-container {
    margin-top: 1.2rem;
  }

  .section-{{ section.id }}-padding .grid.product-grid {
    display: flex;
    flex-wrap: nowrap;
    gap: 2.4rem;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 1.2rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }

  .section-{{ section.id }}-padding .grid.product-grid::-webkit-scrollbar {
    height: 0.8rem;
  }

  .section-{{ section.id }}-padding .grid.product-grid::-webkit-scrollbar-thumb {
    background: rgba(28, 27, 27, 0.2);
    border-radius: 999px;
  }

  .section-{{ section.id }}-padding .grid.product-grid > .grid__item {
    flex: 0 0 clamp(28rem, 32vw, 39rem);
    scroll-snap-align: start;
  }

  .section-{{ section.id }}-padding .card-wrapper {
    height: 100%;
  }

  .section-{{ section.id }}-padding .card {
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  .section-{{ section.id }}-padding .card__inner {
    overflow: hidden;
    background: #f0f0f0;
  }

  .section-{{ section.id }}-padding .card__media {
    position: relative;
    overflow: hidden;
  }

  .section-{{ section.id }}-padding .card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 50% 35%, rgba(255, 255, 255, 0.72), rgba(240, 240, 240, 0.96) 56%, rgba(231, 226, 220, 1) 100%);
  }

  .section-{{ section.id }}-padding .card__placeholder-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
    transform: scale(1.2);
  }

  .section-{{ section.id }}-padding .card__media .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transform: scale(1.12);
    transform-origin: center;
  }

  .section-{{ section.id }}-padding .card__placeholder-copy {
    position: absolute;
    left: 1.6rem;
    right: 1.6rem;
    bottom: 1.6rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.2rem;
    background: rgba(253, 248, 248, 0.68);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(28, 27, 27, 0.08);
    max-width: 28rem;
  }

  .section-{{ section.id }}-padding .card__placeholder-name {
    color: #121212;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 1.3vw, 2.3rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .section-{{ section.id }}-padding .card__placeholder-note {
    color: rgba(28, 27, 27, 0.72);
    font-family: 'Inter', sans-serif;
    font-size: 0.96rem;
    line-height: 1.45;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-{{ section.id }}-padding .media--hover-effect img,
  .section-{{ section.id }}-padding .card__media img {
    transition: transform 1.15s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.35s ease;
  }

  .section-{{ section.id }}-padding .card-wrapper:hover .media--hover-effect img,
  .section-{{ section.id }}-padding .card-wrapper:hover .card__media img {
    transform: scale(1.16);
  }

  .section-{{ section.id }}-padding .card__content {
    padding-top: 1.5rem;
  }

  .section-{{ section.id }}-padding .card__information {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem 1.6rem;
    align-items: end;
  }

  .section-{{ section.id }}-padding .card__heading {
    margin: 0;
  }

  .section-{{ section.id }}-padding .card__heading a {
    color: #121212;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 1.6vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .section-{{ section.id }}-padding .editorial-title {
    color: #121212;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 1.6vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .section-{{ section.id }}-padding .editorial-price {
    margin: 0;
    color: rgba(18, 18, 18, 0.82);
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-align: right;
  }

  .section-{{ section.id }}-padding .editorial-subtitle {
    margin: 0.6rem 0 0;
    color: rgba(28, 27, 27, 0.62);
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .section-{{ section.id }}-padding .price {
    justify-self: end;
    text-align: right;
    margin-top: 0.1rem;
  }

  .section-{{ section.id }}-padding .price-item {
    color: rgba(18, 18, 18, 0.82);
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.16em;
  }

  .section-{{ section.id }}-padding .card__note {
    position: absolute;
    left: 1.6rem;
    right: 1.6rem;
    bottom: 1.6rem;
    z-index: 2;
    padding: 1.2rem 1.4rem;
    background: linear-gradient(180deg, rgba(253, 248, 248, 0) 0%, rgba(253, 248, 248, 0.82) 100%);
    color: rgba(28, 27, 27, 0.76);
    font-family: 'Inter', sans-serif;
    font-size: 0.96rem;
    font-weight: 500;
    line-height: 1.45;
    letter-spacing: 0.03em;
    text-transform: none;
    opacity: 0;
    transform: translateY(1rem);
    transition: opacity 240ms ease, transform 240ms ease;
  }

  .section-{{ section.id }}-padding .card-wrapper:hover .card__note {
    opacity: 1;
    transform: translateY(0);
  }

  .section-{{ section.id }}-padding .card__badge {
    display: none;
  }

  .section-{{ section.id }}-padding .editorial-product-card {
    height: 100%;
  }

  .section-{{ section.id }}-padding .editorial-product-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .section-{{ section.id }}-padding .editorial-product-card .card__inner {
    background: #f4f0ec;
  }

  .section-{{ section.id }}-padding .editorial-product-card .card__inner.ratio {
    --ratio-percent: 125%;
  }

  .section-{{ section.id }}-padding .editorial-product-card .card__media {
    position: relative;
    min-height: 0;
  }

  .section-{{ section.id }}-padding .editorial-product-card .card__media .media {
    background: transparent;
  }

  .section-{{ section.id }}-padding .editorial-product-card .card__media .media img {
    transform: scale(1.18);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding .collection {
      padding-inline: 1.6rem;
    }

    .section-{{ section.id }}-padding .grid.product-grid {
      gap: 1.6rem;
    }

    .section-{{ section.id }}-padding .grid.product-grid > .grid__item {
      flex-basis: 82vw;
    }

    .section-{{ section.id }}-padding .card__information {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .section-{{ section.id }}-padding .price {
      justify-self: start;
      text-align: left;
    }

    .section-{{ section.id }}-padding .card__heading a {
      font-size: 2rem;
    }

    .section-{{ section.id }}-padding .card__note {
      left: 1.2rem;
      right: 1.2rem;
      bottom: 1.2rem;
      padding: 1rem 1.1rem;
      font-size: 0.95rem;
    }

    .section-{{ section.id }}-padding .card__placeholder-copy {
      left: 1.2rem;
      right: 1.2rem;
      bottom: 1.2rem;
      padding: 0.9rem 1rem;
      max-width: none;
    }

    .section-{{ section.id }}-padding .card__placeholder-note {
      font-size: 0.88rem;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <h2 class="facet-filters__label caption-large text-body">
                <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
              </h2>
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: collection.terms, count: collection.results_count
                  }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: collection.products_count, count: collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div
            class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          >
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                grid--{{ section.settings.columns_desktop }}-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {% assign skip_card_product_styles = false %}
            {%- for product in collection.products -%}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}
                <li
                  class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id
                  %}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}

              {%- if collection.handle == 'all' and collection.products_count < 6 -%}
                {%- assign editorial_titles = 'LUNA|AURA NOCTIS|OBSIDIANA|ÉLAN|AURUM & OAK' | split: '|' -%}
                {%- assign editorial_notes = 'Frosted white musk with airy citrus and clean aldehydes.|Deep navy woods with incense, amber, and quiet smoke.|Matte noir oud balanced by warm spice and a polished trail.|Sage vetiver with green florals and a crisp, luminous finish.|Golden woods, soft amber, and a smooth skin-close warmth.' | split: '|' -%}
                {%- assign editorial_prices = '₹2,490|₹2,790|₹2,990|₹2,650|₹2,890' | split: '|' -%}
                {%- assign editorial_subtitles = 'Eau de Parfum|Extrait de Parfum|Parfum Intense|Eau de Parfum|Eau de Parfum' | split: '|' -%}
                {%- assign editorial_assets = 'collection-placeholder-white.png|collection-placeholder-navy.png|collection-placeholder-obsidian.png|collection-placeholder-sage.png|collection-placeholder-amber.png' | split: '|' -%}
                {%- assign editorial_urls = '/collections/men|/collections/perfumes|/collections/women|/collections/unisex|/collections/all' | split: '|' -%}

                {%- for editorial_index in (0..4) -%}
                  <li class="grid__item editorial-card grid__item--collection-editorial">
                    <a href="{{ editorial_urls[editorial_index] }}" class="card-wrapper product-card-wrapper underline-links-hover editorial-product-link editorial-product-card">
                      <div class="card card--standard card--media color-{{ settings.card_color_scheme }} gradient">
                        <div class="card__inner ratio" style="--ratio-percent: 125%;">
                          <div class="card__media">
                            <div class="media media--transparent media--hover-effect">
                              <img
                                src="{{ editorial_assets[editorial_index] | asset_url }}"
                                alt="{{ editorial_titles[editorial_index] | escape }}"
                                loading="lazy"
                                class="motion-reduce"
                                width="1200"
                                height="1500"
                              >
                            </div>
                            <div class="card__note">
                              {{ editorial_notes[editorial_index] }}
                            </div>
                          </div>
                        </div>
                        <div class="card__content">
                          <div class="card__information">
                            <h3 class="card__heading">
                              <span class="full-unstyled-link editorial-title">
                                {{ editorial_titles[editorial_index] }}
                              </span>
                            </h3>
                            <p class="card__price editorial-price">{{ editorial_prices[editorial_index] }}</p>
                          </div>
                          <p class="card__subtitle editorial-subtitle">{{ editorial_subtitles[editorial_index] }}</p>
                        </div>
                      </div>
                    </a>
                  </li>
                {%- endfor -%}
              {%- endif -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },    
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.image_shape.options__1.label"
        },
        {
          "value": "arch",
          "label": "t:sections.all.image_shape.options__2.label"
        },
        {
