<style>
:root{
--wf-header-height:180px;
--wf-header-height-scrolled:70px;
--wf-logo-size:46px;
--wf-logo-size-scrolled:24px;
  --wf-transition:.45s cubic-bezier(.22,.61,.36,1);
}

.wf-header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  z-index:9999;
  background:rgba(255,255,255,.98);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  transition:all var(--wf-transition);
  border-bottom:1px solid rgba(0,0,0,.06);
}

.wf-header-inner{
  max-width:1200px;
  margin:auto;
  height:var(--wf-header-height);
  display:grid;
  grid-template-columns:1fr auto 1fr;
  align-items:center;
  padding:0 40px;
  transition:all var(--wf-transition);
}

.wf-left,
.wf-right{
  display:flex;
  align-items:center;
  gap:30px;
}

.wf-right{
  justify-content:flex-end;
}

.wf-menu-link{
  text-decoration:none;
  color:#111;
  font-size:13px;
  letter-spacing:1.5px;
  text-transform:uppercase;
  font-weight:600;
  transition:.3s;
}

.wf-menu-link:hover{
  opacity:.55;
}

.wf-logo{
  text-decoration:none;
  color:#000;
  font-size:var(--wf-logo-size);
  font-weight:400;
  letter-spacing:0;
  line-height:1;
  transition:all var(--wf-transition);
  transform-origin:center;
  font-family:'Derma', sans-serif;
}

.wf-icon{
  width:20px;
  height:20px;
  cursor:pointer;
}

.wf-header.scrolled{
  box-shadow:0 10px 40px rgba(0,0,0,.08);
}

.wf-header.scrolled .wf-header-inner{
  height:var(--wf-header-height-scrolled);
}

.wf-header.scrolled .wf-logo{
  font-size:var(--wf-logo-size-scrolled);
  transform:translateY(0);
}

.wf-spacer{
  height:160px;
}

@media(max-width:991px){

  .wf-header-inner{
    height:100px;
    padding:0 18px;
    grid-template-columns:auto 1fr auto;
  }

  .wf-left{
    gap:12px;
  }

  .wf-menu-link{
    display:none;
  }

  .wf-logo{
    text-align:center;
    font-size:38px;
  }

  .wf-header.scrolled .wf-logo{
    font-size:26px;
  }

  .wf-spacer{
    height:100px;
  }
}

.wf-mobile-menu{
  display:none;
  font-size:26px;
  cursor:pointer;
}

@media(max-width:991px){
  .wf-mobile-menu{
    display:block;
  }
}
</style>

<header class="wf-header" id="wfHeader">

  <div class="wf-header-inner">

    <div class="wf-left">

      <div class="wf-mobile-menu">
        ☰
      </div>

      <a href="/collections/all" class="wf-menu-link">Shop</a>
      <a href="/pages/about-us" class="wf-menu-link">About</a>
      <a href="/collections/perfumes" class="wf-menu-link">Perfumes</a>

    </div>

    <a href="/" class="wf-logo">
      WILDFYRE
    </a>

    <div class="wf-right">

      <a href="/search">
        <svg class="wf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <a href="/cart">
        <svg class="wf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
      </a>

    </div>

  </div>

</header>

<div class="wf-spacer"></div>

<script>
document.addEventListener('DOMContentLoaded',function(){

  const header = document.getElementById('wfHeader');

  window.addEventListener('scroll',function(){

    if(window.scrollY > 80){
      header.classList.add('scrolled');
    }else{
      header.classList.remove('scrolled');
    }

  });

});
</script>
