<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}
  {%- if product.quantity_price_breaks_configured? -%}
    {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- style -%}
    @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=Hanken+Grotesk:wght@300;400;500;600&display=swap');

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    /* Dossier Design System Styles */
    .dossier-product-container {
      font-family: 'Hanken Grotesk', sans-serif;
      color: #000;
      background: #fff;
    }

    .dossier-product-container h1, 
    .dossier-product-container h2, 
    .dossier-product-container h3,
    .dossier-product-container .font-serif {
      font-family: 'EB Garamond', serif;
    }

    .dossier-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    @media screen and (min-width: 990px) {
      .dossier-grid {
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
      }
    }

    .dossier-image-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }

    .dossier-image-grid .main-image {
      grid-column: 1 / -1;
    }

    .dossier-image-grid img {
      width: 100%;
      height: auto;
      object-fit: cover;
    }

    .dossier-product-info {
      position: relative;
    }

    .dossier-sticky-sidebar {
      position: sticky;
      top: 2rem;
    }

    .dossier-title {
      font-size: 2.25rem;
      font-weight: 500;
      line-height: 1.1;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }

    @media screen and (min-width: 750px) {
      .dossier-title {
        font-size: 3rem;
      }
    }

    .dossier-rating {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      margin-bottom: 0.5rem;
    }

    .dossier-rating .stars {
      color: #fbbf24;
    }

    .dossier-rating .reviews-link {
      text-decoration: underline;
      color: #6b7280;
    }

    .dossier-subtitle {
      font-size: 0.875rem;
      color: #4b5563;
      margin-bottom: 1.5rem;
    }

    .dossier-price-container {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }

    .dossier-price {
      font-size: 0.875rem;
      color: #6b7280;
    }

    .dossier-price .price-value {
      color: #000;
      font-weight: 600;
    }

    .dossier-member-price {
      font-size: 0.875rem;
      color: #dc2626;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .dossier-inspired {
      font-size: 0.875rem;
      font-style: italic;
      color: #374151;
      margin-bottom: 2rem;
    }

    .dossier-inspired strong {
      font-weight: 600;
    }

    .dossier-size-selector {
      margin-bottom: 2rem;
    }

    .dossier-size-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
    }

    .dossier-size-buttons {
      display: flex;
      gap: 0.5rem;
    }

    .dossier-size-btn {
      flex: 1;
      border: 1px solid #d1d5db;
      padding: 0.5rem 2rem;
      font-size: 0.875rem;
      background: #fff;
      cursor: pointer;
      transition: border-color 0.2s;
    }

    .dossier-size-btn:hover {
      border-color: #000;
    }

    .dossier-size-btn.active {
      border: 2px solid #000;
      position: relative;
    }

    .dossier-size-btn .price {
      color: #9ca3af;
      margin-left: 0.5rem;
    }

    .dossier-badges {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    .dossier-badge {
      padding: 0.25rem 0.75rem;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .dossier-badge.gray {
      background: #f3f4f6;
      color: #000;
    }

    .dossier-badge.orange {
      background: #fff7ed;
      color: #9a3412;
    }

    .dossier-add-to-cart {
      width: 100%;
      background: #000;
      color: #fff;
      padding: 1rem;
      font-size: 0.875rem;
      font-weight: 700;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
    }

    .dossier-add-to-cart:hover {
      background: #1f2937;
    }

    .dossier-accordions {
      margin-top: 3rem;
      border-top: 1px solid #e5e7eb;
    }

    .dossier-accordion-item {
      border-bottom: 1px solid #e5e7eb;
      padding: 1rem 0;
    }

    .dossier-accordion-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
    }

    .dossier-accordion-title {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .dossier-accordion-content {
      margin-top: 1.5rem;
      display: none;
    }

    .dossier-accordion-item.open .dossier-accordion-content {
      display: block;
    }

    .dossier-scent-description {
      font-size: 0.875rem;
      background: #f9fafb;
      padding: 1rem;
      display: inline-block;
      border-radius: 9999px;
      margin-bottom: 2rem;
    }

    .dossier-scent-description strong {
      font-style: italic;
      font-weight: 600;
    }

    .dossier-notes-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }

    .dossier-notes-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .dossier-note-item img {
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      margin: 0 auto 0.5rem;
    }

    .dossier-note-name {
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .dossier-note-pyramid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .dossier-note-level {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }

    .dossier-note-level svg {
      width: 1.25rem;
      height: 1.25rem;
      margin-top: 0.25rem;
    }

    .dossier-note-level-label {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .dossier-note-level-label span {
      font-weight: 400;
      text-transform: none;
      color: #4b5563;
      margin-left: 0.25rem;
    }

    .dossier-note-level-value {
      font-size: 0.875rem;
      font-weight: 500;
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- if product.quantity_price_breaks_configured? -%}
    <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  
  <div class="page-width dossier-product-container">
    <div class="dossier-grid">
      <!-- Left Column: Image Gallery -->
      <div class="dossier-image-grid">
        <div class="main-image">
          {% if product.media.size > 0 %}
            {{ product.featured_media | image_url: width: 1200 | image_tag:
              width: 1200,
              height: 1200,
              alt: product.featured_media.alt,
              class: 'dossier-main-image'
            }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        {% for media in product.media limit: 4 offset: 1 %}
          <div>
            {{ media | image_url: width: 600 | image_tag:
              width: 600,
              height: 600,
              alt: media.alt
            }}
          </div>
        {% endfor %}
      </div>

      <!-- Right Column: Product Info -->
      <div class="dossier-product-info">
        <div class="dossier-sticky-sidebar">
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <p
                  class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
              {%- when 'title' -%}
                <div class="dossier-title" {{ block.shopify_attributes }}>
                  <h1>{{ product.title | escape }}</h1>
                </div>
                
                <div class="dossier-rating">
                  <div class="stars">★★★★★</div>
                  <a href="#reviews" class="reviews-link">
                    {%- if product.metafields.reviews.rating_count -%}
                      {{ product.metafields.reviews.rating_count }} reviews
                    {%- else -%}
                      See reviews
                    {%- endif -%}
                  </a>
                </div>

                <p class="dossier-subtitle">
                  Eau de Parfum. Size: 100ml / 3.4oz
                </p>

                <div class="dossier-price-container">
                  <div class="dossier-price">
                    Guest: <span class="price-value">{{ product.price | money }}</span>
                  </div>
                  <div class="dossier-member-price">
                    {%- if product.compare_at_price > product.price -%}
                      Member: {{ product.compare_at_price | money }}
                    {%- else -%}
                      Member: {{ product.price | times: 0.9 | money }}
                    {%- endif -%}
                  </div>
                </div>
              {%- when 'variant_picker' -%}
                <div class="dossier-size-selector" {{ block.shopify_attributes }}>
                  <h3 class="dossier-size-label">Size</h3>
                  <div class="dossier-size-buttons">
                    {% for variant in product.variants %}
                      <button 
                        class="dossier-size-btn {% if variant == product.selected_or_first_available_variant %}active{% endif %}"
                        data-variant-id="{{ variant.id }}"
                        onclick="selectVariant({{ variant.id }})"
                      >
                        {{ variant.title }} <span class="price">{{ variant.price | money }}</span>
                      </button>
                    {% endfor %}
                  </div>
                </div>

                <div class="dossier-badges">
                  <span class="dossier-badge gray">Crafted in France</span>
                  <span class="dossier-badge orange">Scent Family: Warm</span>
                </div>

              {%- when 'buy_buttons' -%}
                {%- form 'product', product, id: product_form_id, class: 'dossier-form', data-type: 'add-to-cart-form' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled>
                  <button 
                    type="submit" 
                    name="add"
                    class="dossier-add-to-cart"
                    {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                  >
                    {%- if product.selected_or_first_available_variant.available -%}
                      Add to Cart
                    {%- else -%}
                      Sold out
                    {%- endif -%}
                  </button>
                {%- endform -%}
              {%- when 'inventory' -%}
                <p
                  class="product__inventory{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                  {{ block.shopify_attributes }}
                  id="Inventory-{{ section.id }}"
                  role="status"
                >
                  {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity
                          <= block.settings.inventory_threshold
                      -%}
                        <span class="svg-wrapper" style="color: rgb(238, 148, 65)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_low_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_low_stock' | t -}}
                        {%- endif -%}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_in_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_in_stock' | t -}}
                        {%- endif -%}
                      {%- endif -%}
                    {%- else -%}
                      {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(200, 200, 200)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                </p>
              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
                    {{ product.description }}
                  </div>
                {%- endif -%}
              {%- when 'sku' -%}
                <p
                  class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                  id="Sku-{{ section.id }}"
                  role="status"
                  {{ block.shopify_attributes }}
                >
                  <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                  {{- product.selected_or_first_available_variant.sku -}}
                </p>
              {%- when 'custom_liquid' -%}
                {{ block.settings.custom_liquid }}
              {%- when 'collapsible_tab' -%}
                <div class="dossier-accordions" {{ block.shopify_attributes }}>
                  <div class="dossier-accordion-item" data-accordion="scent-notes">
                    <div class="dossier-accordion-header" onclick="toggleAccordion('scent-notes')">
                      <h3 class="dossier-accordion-title">Scent Notes</h3>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div class="dossier-accordion-content" id="scent-notes-content">
                      <p class="dossier-scent-description">This perfume is: <strong>Warm, a whiff of wealth</strong></p>
                      <h4 class="dossier-notes-label">Main Notes:</h4>
                      <div class="dossier-notes-grid">
                        <div class="dossier-note-item">
                          <img src="https://via.placeholder.com/48" alt="Saffron">
                          <p class="dossier-note-name">Saffron</p>
                        </div>
                        <div class="dossier-note-item">
                          <img src="https://via.placeholder.com/48" alt="Orange Blossom">
                          <p class="dossier-note-name">Orange Blossom</p>
                        </div>
                        <div class="dossier-note-item">
                          <img src="https://via.placeholder.com/48" alt="Cedarwood">
                          <p class="dossier-note-name">Cedarwood</p>
                        </div>
                        <div class="dossier-note-item">
                          <img src="https://via.placeholder.com/48" alt="Amber">
                          <p class="dossier-note-name">Amber</p>
                        </div>
                      </div>
                      <div class="dossier-note-pyramid">
                        <div class="dossier-note-level">
                          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                          <div>
                            <p class="dossier-note-level-label">Top: <span>The first notes you smell</span></p>
                            <p class="dossier-note-level-value">Saffron, Orange Blossom</p>
                          </div>
                        </div>
                        <div class="dossier-note-level">
                          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                          <div>
                            <p class="dossier-note-level-label">Middle: <span>The heart of the perfume</span></p>
                            <p class="dossier-note-level-value">Jasmine, Plum, Cedarwood</p>
                          </div>
                        </div>
                        <div class="dossier-note-level">
                          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                          <div>
                            <p class="dossier-note-level-label">Base: <span>The notes that linger all day</span></p>
                            <p class="dossier-note-level-value">Oakmoss, Fir Balsam, Amber</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="dossier-accordion-item" data-accordion="about">
                    <div class="dossier-accordion-header" onclick="toggleAccordion('about')">
                      <h3 class="dossier-accordion-title">About</h3>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div class="dossier-accordion-content" id="about-content">
                      <div class="rte">
                        {{ block.settings.content }}
                        {{ block.settings.page.content }}
                      </div>
                    </div>
                  </div>
                  <div class="dossier-accordion-item" data-accordion="shipping">
                    <div class="dossier-accordion-header" onclick="toggleAccordion('shipping')">
                      <h3 class="dossier-accordion-title">Shipping</h3>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div class="dossier-accordion-content" id="shipping-content">
                      <div class="rte">
                        {{ shop.shipping_policy.body }}
                      </div>
                    </div>
                  </div>
                  <div class="dossier-accordion-item" data-accordion="returns">
                    <div class="dossier-accordion-header" onclick="toggleAccordion('returns')">
                      <h3 class="dossier-accordion-title">Returns</h3>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <div class="dossier-accordion-content" id="returns-content">
                      <div class="rte">
                        {{ shop.refund_policy.body }}
                      </div>
                    </div>
                  </div>
                </div>
              {%- when 'quantity_selector' -%}
                <!-- Hidden for dossier design - quantity handled via variant selection -->
              {%- when 'popup' -%}
                <modal-opener
                  class="product-popup-modal__opener quick-add-hidden"
                  data-modal="#PopupModal-{{ block.id }}"
                  {{ block.shopify_attributes }}
                >
                  <button
                    id="ProductPopup-{{ block.id }}"
                    class="product-popup-modal__button link"
                    type="button"
                    aria-haspopup="dialog"
                  >
                    {{ block.settings.text | default: block.settings.page.title | escape }}
                  </button>
                </modal-opener>
              {%- when 'share' -%}
                {% liquid
                  assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
                  render 'share-button', block: block, share_link: share_url
                %}
              {%- when 'rating' -%}
                <!-- Rating already displayed in title block -->
              {%- when 'complementary' -%}
                <product-recommendations
                  class="complementary-products quick-add-hidden{% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}"
                  data-url="{{ routes.product_recommendations_url }}?limit={{ block.settings.product_list_limit }}&intent=complementary"
                  data-section-id="{{ section.id }}"
                  data-product-id="{{ product.id }}"
                >
                  {%- if recommendations.performed and recommendations.products_count > 0 -%}
                    <aside
                      aria-label="{{ 'accessibility.complementary_products' | t }}"
                      {{ block.shopify_attributes -}}
                      {% if block.settings.make_collapsible_row %}
                        class="product__accordion accordion"
                      {% endif %}
                    >
                      <div class="complementary-products__container">
                        {%- if block.settings.make_collapsible_row -%}
                          <details id="Details-{{ block.id }}-{{ section.id }}" open>
                            <summary>
                        {%- endif %}
                        <div class="summary__title">
                          {%- if block.settings.make_collapsible_row -%}
                            {% render 'icon-accordion', icon: block.settings.icon %}
                            <h2 class="h4 accordion__title">{{ block.settings.block_heading }}</h2>
                          {%- else -%}
                            <h2 class="h3 accordion__title">{{ block.settings.block_heading }}</h2>
                          {%- endif -%}
                        </div>
                        {%- if block.settings.make_collapsible_row -%}
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                          </summary>
                        {%- endif -%}
                        <slideshow-component class="slider-mobile-gutter">
                          {%- assign number_of_slides = recommendations.products_count
                            | plus: 0.0
                            | divided_by: block.settings.products_per_page
                            | ceil
                          -%}
                          <div
                            id="Slider-{{ block.id }}"
                            class="contains-card contains-card--product complementary-slider grid grid--1-col slider slider--everywhere"
                            role="list"
                            {% if number_of_slides > 1 %}
                              aria-label="{{ 'general.slider.name' | t }}"
                            {% endif %}
                          >
                            {% assign skip_card_product_styles = false %}
                            {%- for i in (1..number_of_slides) -%}
                              <div
                                id="Slide-{{ block.id }}-{{ forloop.index }}"
                                class="complementary-slide complementary-slide--{{ settings.card_style }} grid__item slider__slide slideshow__slide"
                                tabindex="-1"
                                role="group"
                                {% if number_of_slides > 1 %}
                                  aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
                                  aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                {% endif %}
                              >
                                <ul class="list-unstyled" role="list">
                                  {%- for product in recommendations.products
                                    limit: block.settings.products_per_page
                                    offset: continue
                                  -%}
                                    <li>
                                      {%- if block.settings.enable_quick_add -%}
                                        {% assign quick_add = 'standard' %}
                                      {%- else -%}
                                        {% assign quick_add = 'none' %}
                                      {%- endif -%}
                                      {% render 'card-product',
                                        card_product: product,
                                        media_aspect_ratio: block.settings.image_ratio,
                                        show_secondary_image: false,
                                        lazy_load: false,
                                        skip_styles: skip_card_product_styles,
                                        quick_add: quick_add,
                                        section_id: section.id,
                                        horizontal_class: true,
                                      %}
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              </div>
                            {%- endfor -%}
                          </div>
                          {%- if number_of_slides > 1 -%}
                            <div class="slider-buttons no-js-hidden">
                              <button
                                type="button"
                                class="slider-button slider-button--prev"
                                name="previous"
                                aria-label="{{ 'general.slider.previous_slide' | t }}"
                                aria-controls="Slider-{{ block.id }}"
                              >
                                {% render 'icon-caret' %}
                              </button>
                              <div class="slider-counter caption">
                                <span class="slider-counter--current">1</span>
                                <span aria-hidden="true"> / </span>
                                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                <span class="slider-counter--total">{{ number_of_slides }}</span>
                              </div>
                              <button
                                type="button"
                                class="slider-button slider-button--next"
                                name="next"
                                aria-label="{{ 'general.slider.next_slide' | t }}"
                                aria-controls="Slider-{{ block.id }}"
                              >
                                {% render 'icon-caret' %}
                              </button>
                            </div>
                          {%- endif -%}
                        </slideshow-component>
                      </div>
                    </aside>
                  {%- endif -%}
                </product-recommendations>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleAccordion(id) {
      const accordion = document.querySelector(`[data-accordion="${id}"]`);
      const content = document.getElementById(`${id}-content`);
      
      if (accordion.classList.contains('open')) {
        accordion.classList.remove('open');
        content.style.display = 'none';
      } else {
        // Close all other accordions
        document.querySelectorAll('.dossier-accordion-item').forEach(item => {
          item.classList.remove('open');
          const itemContent = item.querySelector('.dossier-accordion-content');
          if (itemContent) {
            itemContent.style.display = 'none';
          }
        });
        
        accordion.classList.add('open');
        content.style.display = 'block';
      }
    }

    function selectVariant(variantId) {
      // Update active state on buttons
      document.querySelectorAll('.dossier-size-btn').forEach(btn => {
        btn.classList.remove('active');
        if (parseInt(btn.dataset.variantId) === variantId) {
          btn.classList.add('active');
        }
      });

      // Update hidden input in form
      const variantInput = document.querySelector('input[name="id"]');
      if (variantInput) {
        variantInput.value = variantId;
        variantInput.disabled = false;
      }

      // Update price display
      const variant = {{ product.variants | json }}.find(v => v.id === variantId);
      if (variant) {
        const priceValue = document.querySelector('.price-value');
        const memberPrice = document.querySelector('.dossier-member-price');
        
        if (priceValue) {
          priceValue.textContent = new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: '{{ cart.currency.iso_code }}'
          }).format(variant.price / 100);
        }
        
        if (memberPrice && variant.compare_at_price) {
          memberPrice.textContent = 'Member: ' + new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: '{{ cart.currency.iso_code }}'
          }).format(variant.compare_at_price / 100);
        } else if (memberPrice) {
          memberPrice.textContent = 'Member: ' + new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: '{{ cart.currency.iso_code }}'
          }).format(variant.price * 0.9 / 100);
        }
      }
    }

    // Initialize first accordion as open
    document.addEventListener('DOMContentLoaded', function() {
      const firstAccordion = document.querySelector('.dossier-accordion-item');
      if (firstAccordion) {
        toggleAccordion(firstAccordion.dataset.accordion);
      }
    });
  </script>
</product-info>

