    "custom_liquid_K7hdbB": {
      "type": "custom-liquid",
      "name": "MEN WOMEN TAB",
      "settings": {
        "custom_liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Inter:wght@300;400;500&display=swap');\n\n/* SECTION */\n\n.wf-luxury{\nposition:relative;\nwidth:100%;\nheight:100vh;\noverflow:hidden;\nbackground:#000;\n}\n\n/* CUSTOM CURSOR */\n\n@media(min-width:769px){\n\nbody{\ncursor:auto;\n}\n\n#wf-dot{\ndisplay:none;\nposition:fixed;\nwidth:10px;\nheight:10px;\nbackground:#fff;\nborder-radius:50%;\npointer-events:none;\nz-index:999999;\ntransform:translate(-50%,-50%);\n}\n\n#wf-circle{\ndisplay:none;\nposition:fixed;\nwidth:40px;\nheight:40px;\nborder:1px solid rgba(255,255,255,.8);\nborder-radius:50%;\npointer-events:none;\nz-index:999998;\ntransform:translate(-50%,-50%);\ntransition:all .3s ease;\n}\n\n.wf-hovering #wf-circle{\nwidth:75px;\nheight:75px;\n}\n\n}\n\n/* GRID */\n\n.wf-split{\ndisplay:grid;\ngrid-template-columns:repeat(3,1fr);\nheight:100%;\n}\n\n.wf-panel{\nposition:relative;\noverflow:hidden;\ntext-decoration:none;\ncolor:#fff;\ncursor:pointer;\n}\n\n.wf-panel img{\nposition:absolute;\ninset:0;\nwidth:100%;\nheight:100%;\nobject-fit:cover;\ntransition:transform 1.5s ease;\n}\n\n.wf-panel:hover img{\ntransform:scale(1.08);\n}\n\n.wf-panel::before{\ncontent:'';\nposition:absolute;\ninset:0;\nbackground:linear-gradient(\nto bottom,\nrgba(0,0,0,.05),\nrgba(0,0,0,.15),\nrgba(0,0,0,.75)\n);\nz-index:1;\n}\n\n/* TITLE */\n\n.wf-title{\nposition:absolute;\ntop:8%;\nleft:50%;\ntransform:translateX(-50%);\nz-index:3;\n\nfont-family:'Cormorant Garamond',serif;\nfont-size:clamp(60px,7vw,140px);\nfont-weight:600;\nletter-spacing:.08em;\ncolor:#fff;\nwidth:100%;\ntext-align:center;\n}\n\n/* BOTTOM CONTENT */\n\n.wf-content{\nposition:absolute;\nleft:40px;\nright:40px;\nbottom:40px;\n\ndisplay:flex;\njustify-content:space-between;\nalign-items:flex-end;\n\nz-index:3;\n}\n\n.wf-label{\nfont-family:Inter,sans-serif;\nfont-size:11px;\nletter-spacing:.25em;\ntext-transform:uppercase;\ncolor:rgba(255,255,255,.7);\nmargin-bottom:10px;\n}\n\n.wf-link{\nfont-family:Inter,sans-serif;\nfont-size:13px;\nletter-spacing:.15em;\ntext-transform:uppercase;\ncolor:#fff;\n}\n\n.wf-arrow{\nwidth:58px;\nheight:58px;\nborder-radius:50%;\nbackground:#fff;\ncolor:#000;\n\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n\nfont-size:22px;\ntransition:.3s ease;\n}\n\n.wf-panel:hover .wf-arrow{\ntransform:scale(1.1);\n}\n\n/* MOBILE */\n\n@media(max-width:768px){\n\nbody{\ncursor:auto;\n}\n\n#wf-dot,\n#wf-circle{\ndisplay:none;\n}\n\n.wf-luxury{\nheight:auto;\n}\n\n.wf-split{\ngrid-template-columns:1fr;\n}\n\n.wf-panel{\nheight:80vh;\n}\n\n.wf-title{\nfont-size:24vw;\ntop:40px;\n}\n\n.wf-content{\nleft:25px;\nright:25px;\nbottom:25px;\n}\n\n}\n</style>\n\n<div id=\"wf-dot\"></div>\n<div id=\"wf-circle\"></div>\n\n<section class=\"wf-luxury\">\n\n<div class=\"wf-split\">\n\n<a href=\"/collections/men\" class=\"wf-panel\">\n\n<img src=\"https://cdn.shopify.com/s/files/1/0906/2835/8514/files/pexels-anna-ginger-2157748733-34952011.jpg?v=1780577945\">\n\n<div class=\"wf-title\">MEN</div>\n\n<div class=\"wf-content\">\n<div>\n<div class=\"wf-label\">SIGNATURE COLLECTION</div>\n<div class=\"wf-link\">Explore Collection</div>\n</div>\n<div class=\"wf-arrow\">→</div>\n</div>\n\n</a>\n\n<a href=\"/collections/women\" class=\"wf-panel\">\n\n<img src=\"https://cdn.shopify.com/s/files/1/0906/2835/8514/files/pexels-petrovskii-anton-123395531-12900452.jpg?v=1780576839\">\n\n<div class=\"wf-title\">WOMEN</div>\n\n<div class=\"wf-content\">\n<div>\n<div class=\"wf-label\">LUXURY COLLECTION</div>\n<div class=\"wf-link\">Explore Collection</div>\n</div>\n<div class=\"wf-arrow\">→</div>\n</div>\n\n</a>\n\n<a href=\"/collections/unisex\" class=\"wf-panel\">\n\n<img src=\"https://cdn.shopify.com/s/files/1/0906/2835/8514/files/pexels-andrea-acosta-1058133719-22805432.jpg?v=1780577158\">\n\n<div class=\"wf-title\">UNISEX</div>\n\n<div class=\"wf-content\">\n<div>\n<div class=\"wf-label\">TIMELESS COLLECTION</div>\n<div class=\"wf-link\">Explore Collection</div>\n</div>\n<div class=\"wf-arrow\">→</div>\n</div>\n\n</a>\n\n</div>\n\n</section>\n\n<script>\nconst dot=document.getElementById('wf-dot');\nconst circle=document.getElementById('wf-circle');\n\nif(window.innerWidth > 768){\n\nlet mx=0,my=0,cx=0,cy=0;\n\ndocument.addEventListener('mousemove',(e)=>{\n\nmx=e.clientX;\nmy=e.clientY;\n\ndot.style.left=mx+'px';\ndot.style.top=my+'px';\n\n});\n\nfunction animate(){\n\ncx+=(mx-cx)*0.15;\ncy+=(my-cy)*0.15;\n\ncircle.style.left=cx+'px';\ncircle.style.top=cy+'px';\n\nrequestAnimationFrame(animate);\n\n}\n\nanimate();\n\ndocument.querySelectorAll('.wf-panel').forEach(panel=>{\n\npanel.addEventListener('mouseenter',()=>{\ndocument.body.classList.add('wf-hovering');\n});\n\npanel.addEventListener('mouseleave',()=>{\ndocument.body.classList.remove('wf-hovering');\n});\n\n});\n\n}\n</script>",
